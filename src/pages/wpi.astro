---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import WpiPraticaSection from '../components/WpiPraticaSection.astro';
import WpiConexaoSection from '../components/WpiConexaoSection.astro';
import ContatoFooter from '../components/ContatoFooter.astro';
---
<Layout title="WPI | TG Agency">
  <Header />
  <main>
    <section class="wpi-hero">
      <div class="wpi-hero__bg">
        <img src="/images/wpi_hero_bg.jpg" alt="" class="wpi-hero__bg-img" />
      </div>
      <div class="wpi-hero__overlay"></div>
      <div class="wpi-hero__content">
        <div class="wpi-hero__logos">
          <img src="/images/wpi_logo.png" alt="WPI" class="wpi-hero__logo-wpi" width="225" height="67" />
          <div class="wpi-hero__divider"></div>
          <img src="/images/wpi_tg_logo.png" alt="TG" class="wpi-hero__logo-tg" width="106" height="81" />
        </div>
        <h1>Aqui tem autonomia local.<br />E conexão global.</h1>
      </div>
    </section>
    <WpiPraticaSection />
    <WpiConexaoSection />
  </main>
  <ContatoFooter />
</Layout>

<style>
  .wpi-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0d0d0d;
  }

  .wpi-hero__bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .wpi-hero__bg-img {
    position: absolute;
    left: 0;
    top: 3.11%;
    width: 100%;
    height: 121.98%;
    object-fit: cover;
  }

  .wpi-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.2);
  }

  .wpi-hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
    padding: 0 165px;
    text-align: center;
  }

  .wpi-hero__content h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 8.16vw, 7.3rem);
    line-height: 0.98;
    color: #fff;
    margin: 0;
  }

  .wpi-hero__logos {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .wpi-hero__logo-wpi {
    width: 225px;
    height: 67px;
    object-fit: cover;
  }

  .wpi-hero__divider {
    width: 1px;
    height: 86px;
    background: #fff;
    flex-shrink: 0;
  }

  .wpi-hero__logo-tg {
    width: 106px;
    height: 81px;
    object-fit: cover;
  }
</style>
