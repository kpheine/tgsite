---
import AdminLayout from '../../../components/AdminLayout.astro';
import { adminUrl, isAdminPath, requireUser } from '../../../lib/auth';
import { db, type CaseImageRecord, type CaseRecord } from '../../../lib/db';

if (!isAdminPath(Astro.params.adminPath)) {
  return new Response('Não encontrado', { status: 404 });
}

const user = requireUser(Astro.cookies);
if (!user) return Astro.redirect(adminUrl('login'));

const item = db.prepare('SELECT * FROM cases WHERE id = ?').get(Astro.params.id) as CaseRecord | undefined;
if (!item) return new Response('Não encontrado', { status: 404 });

const images = db.prepare('SELECT * FROM imagens_case WHERE case_id = ? ORDER BY sort_order ASC, id ASC').all(item.id) as CaseImageRecord[];
---
<AdminLayout title={`Editar ${item.titulo}`} email={user.email}>
  <header class="admin-header">
    <div>
      <p class="admin-kicker">Editar conteúdo</p>
      <h1 class="admin-title">{item.titulo}</h1>
    </div>
  </header>

  <form class="admin-form" method="post" action={`/api/panel/cases/${item.id}`} enctype="multipart/form-data">
    <div class="admin-form-row">
      <div class="admin-field"><label for="titulo">Título</label><input class="admin-input" id="titulo" name="titulo" value={item.titulo} required /></div>
      <div class="admin-field"><label for="cliente">Cliente</label><input class="admin-input" id="cliente" name="cliente" value={item.cliente || ''} /></div>
    </div>
    <div class="admin-form-row">
      <div class="admin-field"><label for="status">Status</label><select class="admin-select" id="status" name="status"><option value="draft" selected={item.status === 'draft'}>Rascunho</option><option value="published" selected={item.status === 'published'}>Publicado</option></select></div>
      <div class="admin-field"><label for="sort_order">Ordem</label><input class="admin-input" id="sort_order" name="sort_order" type="number" value={item.sort_order} /></div>
    </div>
    <div class="admin-field">
      <label for="video">Vídeo do case</label>
      {item.video_url && (
        <div class="admin-video-current">
          <p class="admin-muted">Vídeo atual:</p>
          <video src={item.video_url} controls playsinline></video>
        </div>
      )}
      <input class="admin-input" id="video" name="video" type="file" accept="video/*" data-video-input />
      <div class="admin-video-preview" data-video-preview hidden>
        <p class="admin-muted">Prévia do novo vídeo selecionado:</p>
        <video controls playsinline data-video-preview-player></video>
      </div>
    </div>
    <div class="admin-field"><label for="desafio">Desafio</label><textarea class="admin-textarea" id="desafio" name="desafio">{item.desafio || ''}</textarea></div>
    <div class="admin-field"><label for="entrega">Entrega</label><textarea class="admin-textarea" id="entrega" name="entrega">{item.entrega || ''}</textarea></div>
    <div class="admin-field"><label for="resultado">Resultado</label><textarea class="admin-textarea" id="resultado" name="resultado">{item.resultado || ''}</textarea></div>

    <div class="admin-field">
      <label>Imagens atuais</label>
      {images.length === 0 && <p class="admin-muted">Nenhuma imagem adicionada ainda.</p>}
      <div class="admin-image-list">
        {images.map((image) => (
          <article class="admin-image-card">
            <input type="hidden" name="image_id" value={image.id} />
            <a href={image.url} target="_blank" rel="noreferrer"><img src={image.url} alt="" /></a>
            <div class="admin-form-row admin-form-row--compact">
              <div class="admin-field"><label for={`image_order_${image.id}`}>Ordem</label><input class="admin-input" id={`image_order_${image.id}`} name={`image_order_${image.id}`} type="number" value={image.sort_order} /></div>
              <label class="admin-checkbox"><input type="checkbox" name={`image_destaque_${image.id}`} value="1" checked={image.destaque === 1} /> Destaque</label>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="admin-field"><label for="images">Adicionar imagens</label><input class="admin-input" id="images" name="images" type="file" accept="image/*" multiple /></div>
    <div class="admin-actions"><button class="admin-button admin-button--primary" type="submit">Salvar alterações</button><a class="admin-button" href={adminUrl('cases')}>Voltar</a></div>
  </form>

  <form class="admin-form" method="post" action={`/api/panel/cases/${item.id}`} style="margin-top: 18px;">
    <input type="hidden" name="_action" value="delete" />
    <p class="admin-muted">Excluir remove o case, suas imagens e seu vídeo do banco e do disco.</p>
    <button class="admin-button admin-button--danger" type="submit">Excluir case</button>
  </form>
</AdminLayout>

<script>
  const videoInput = document.querySelector<HTMLInputElement>('[data-video-input]');
  const preview = document.querySelector<HTMLElement>('[data-video-preview]');
  const player = document.querySelector<HTMLVideoElement>('[data-video-preview-player]');
  let previewUrl: string | null = null;

  videoInput?.addEventListener('change', () => {
    if (previewUrl) URL.revokeObjectURL(previewUrl);

    const file = videoInput.files?.[0];
    if (!file || !preview || !player) {
      preview?.setAttribute('hidden', '');
      return;
    }

    previewUrl = URL.createObjectURL(file);
    player.src = previewUrl;
    preview.removeAttribute('hidden');
  });
</script>
