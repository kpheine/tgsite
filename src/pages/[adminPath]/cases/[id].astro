---
import AdminLayout from '../../../components/AdminLayout.astro';
import AdminCaseImageCard from '../../../components/AdminCaseImageCard.astro';
import { adminUrl, isAdminPath, requireUser } from '../../../lib/auth';
import { db, type CaseImageRecord, type CaseRecord } from '../../../lib/db';

if (!isAdminPath(Astro.params.adminPath)) {
  return new Response('Não encontrado', { status: 404 });
}

const user = requireUser(Astro.cookies);
if (!user) return Astro.redirect(adminUrl('login'));

const item = db.prepare('SELECT * FROM cases WHERE id = ?').get(Astro.params.id) as CaseRecord | undefined;
if (!item) return new Response('Não encontrado', { status: 404 });

const images = db.prepare('SELECT * FROM imagens_case WHERE case_id = ? ORDER BY sort_order ASC, id ASC').all(item.id) as CaseImageRecord[];
---
<AdminLayout title={`Editar ${item.titulo}`} username={user.username}>
  <header class="admin-header">
    <div>
      <p class="admin-kicker">Editar conteúdo</p>
      <h1 class="admin-title">{item.titulo}</h1>
    </div>
  </header>

  <form class="admin-form" method="post" action={`/api/panel/cases/${item.id}`} enctype="multipart/form-data" data-case-form>
    <div class="admin-form-row">
      <div class="admin-field"><label for="titulo">Título</label><input class="admin-input" id="titulo" name="titulo" value={item.titulo} required /></div>
      <div class="admin-field"><label for="cliente">Cliente</label><input class="admin-input" id="cliente" name="cliente" value={item.cliente || ''} /></div>
    </div>
    <div class="admin-field" data-status-toggle-field>
      <label for="status">Status</label>
      <input id="status" name="status" type="hidden" value={item.status} data-status-toggle-input />
      <button class="admin-status-toggle" type="button" data-status-toggle aria-pressed={item.status === 'published' ? 'true' : 'false'}>
        <span data-status-toggle-label>{item.status === 'published' ? 'Publicado' : 'Rascunho'}</span>
        <small>Clique aqui para mudar o status</small>
      </button>
    </div>
    <div class="admin-field" data-main-image-upload>
      <label for="main_image">Imagem principal do case</label>
      <div class="admin-main-image-current admin-main-image-current--replace" data-main-image-zone>
        <p class="admin-muted">Imagem principal atual</p>
        <div class="admin-main-image-frame">
          <img src={item.main_image_url} alt="" data-main-image-current-img />
          <button class="admin-main-image-replace" type="button" data-main-image-button>
            Clique aqui ou arraste uma imagem para substituir
          </button>
          <button class="admin-main-image-revert" type="button" data-main-image-revert hidden>
            Reverter troca
          </button>
        </div>
        <input class="admin-file-input" id="main_image" name="main_image" type="file" accept="image/*" data-main-image-input />
      </div>
      <div class="admin-main-image-selection" data-main-image-preview hidden>
        <strong data-main-image-name></strong>
        <span class="admin-muted" data-main-image-size></span>
      </div>
      <p class="admin-muted">A substituição só será aplicada ao salvar alterações.</p>
    </div>
    <div class="admin-field" data-video-upload>
      <label for="video">Vídeo do case</label>
      {item.video_url && (
        <div class="admin-video-current" data-current-video-card>
          <div class="admin-case-image-card__banner" data-current-video-banner hidden>Será removido</div>
          <div class="admin-video-preview__header">
            <div>
              <p class="admin-muted">Vídeo atual</p>
              <strong>Este vídeo será mantido se nenhum novo vídeo for selecionado.</strong>
            </div>
            <button class="admin-image-action admin-image-action--remove" type="button" data-remove-current-video>Remover vídeo atual</button>
          </div>
          <button class="admin-video-lazy" type="button" data-current-video-load data-video-src={item.video_url}>
            <span class="admin-video-lazy__icon" aria-hidden="true">▶</span>
            <span>
              <strong>Carregar vídeo atual</strong>
              <span>Clique para pré-visualizar sem baixar automaticamente.</span>
            </span>
          </button>
          <video controls playsinline preload="none" data-current-video-player hidden></video>
          <input type="hidden" name="remove_video" value="1" data-remove-current-video-input disabled />
        </div>
      )}
      <div class="admin-video-preview" data-video-preview hidden>
        <div class="admin-video-preview__header">
          <div>
            <p class="admin-muted">Novo vídeo selecionado</p>
            <strong data-video-name></strong>
            <span class="admin-muted" data-video-size></span>
            <span class="admin-muted" data-video-type></span>
          </div>
          <div class="admin-video-actions">
            <button class="admin-image-action" type="button" data-video-button>Trocar vídeo</button>
            <button class="admin-image-action admin-image-action--remove" type="button" data-video-remove-selection>Remover seleção</button>
          </div>
        </div>
        <video controls playsinline data-video-preview-player></video>
      </div>
      <div class="admin-video-upload" data-video-zone>
        <input class="admin-file-input" id="video" name="video" type="file" accept="video/*" data-video-input />
        <div>
          <strong>{item.video_url ? 'Solte um novo vídeo aqui' : 'Solte o vídeo aqui'}</strong>
          <p class="admin-muted">MP4, WebM ou MOV até 2GB. {item.video_url ? 'Um novo arquivo substitui o vídeo atual ao salvar.' : 'A prévia aparece antes de salvar o case.'}</p>
        </div>
        <button class="admin-button" type="button" data-video-button>Selecionar vídeo</button>
      </div>
      <p class="admin-alert admin-alert--compact" data-video-message hidden></p>
    </div>
    <div class="admin-field"><label for="desafio">Desafio</label><textarea class="admin-textarea" id="desafio" name="desafio">{item.desafio || ''}</textarea></div>
    <div class="admin-field"><label for="entrega">Entrega</label><textarea class="admin-textarea" id="entrega" name="entrega">{item.entrega || ''}</textarea></div>
    <div class="admin-field"><label for="resultado">Resultado</label><textarea class="admin-textarea" id="resultado" name="resultado">{item.resultado || ''}</textarea></div>

    <div class="admin-field" data-image-upload>
      <label for="images">Adicionar imagens</label>
      <div class="admin-upload-zone" data-upload-zone>
        <input class="admin-file-input" id="images" name="images" type="file" accept="image/*" multiple data-upload-input />
        <div>
          <strong>Solte novas imagens aqui</strong>
          <p class="admin-muted">As imagens selecionadas entram na grade abaixo. Arraste qualquer card para definir a ordem final.</p>
        </div>
        <button class="admin-button" type="button" data-upload-button>Selecionar imagens</button>
      </div>
      <template data-upload-card-template><AdminCaseImageCard mode="upload-template" /></template>
      <label>Imagens do case</label>
      {images.length === 0 && <p class="admin-muted">Nenhuma imagem adicionada ainda.</p>}
      <div class="admin-image-list" data-image-list>
        {images.map((image) => (
          <AdminCaseImageCard mode="existing" id={image.id} url={image.url} destaque={image.destaque === 1} order={image.sort_order} />
        ))}
      </div>
    </div>
    <div class="admin-actions"><button class="admin-button admin-button--primary" type="submit">Salvar alterações</button><a class="admin-button" href={adminUrl('cases')}>Voltar</a></div>
  </form>

  <form class="admin-form" method="post" action={`/api/panel/cases/${item.id}`} style="margin-top: 18px;" data-case-delete-form>
    <input type="hidden" name="_action" value="delete" />
    <p class="admin-muted">Excluir remove o case, suas imagens e seu vídeo do banco e do disco.</p>
    <button class="admin-button admin-button--danger" type="submit">Excluir case</button>
  </form>
</AdminLayout>
