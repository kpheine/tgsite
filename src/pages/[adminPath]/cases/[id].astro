---
import AdminLayout from '../../../components/AdminLayout.astro';
import AdminCaseForm from '../../../components/AdminCaseForm.astro';
import { adminUrl, isAdminPath, requireUser } from '../../../lib/auth';
import { db, type CaseImageRecord, type CaseRecord } from '../../../lib/db';

if (!isAdminPath(Astro.params.adminPath)) {
  return new Response('Não encontrado', { status: 404 });
}

const user = requireUser(Astro.cookies);
if (!user) return Astro.redirect(adminUrl('login'));

const item = db.prepare('SELECT * FROM cases WHERE id = ?').get(Astro.params.id) as CaseRecord | undefined;
if (!item) return new Response('Não encontrado', { status: 404 });

const images = db.prepare('SELECT * FROM imagens_case WHERE case_id = ? ORDER BY sort_order ASC, id ASC').all(item.id) as CaseImageRecord[];
---
<AdminLayout title={`Editar ${item.titulo}`} username={user.username}>
  <header class="admin-header">
    <div>
      <p class="admin-kicker">Editar conteúdo</p>
      <h1 class="admin-title">{item.titulo}</h1>
    </div>
  </header>

  <AdminCaseForm item={item} images={images} />

  <form class="admin-form" method="post" action={`/api/panel/cases/${item.id}`} style="margin-top: 18px;" data-case-delete-form>
    <input type="hidden" name="_action" value="delete" />
    <p class="admin-muted">Excluir remove o case, suas imagens e seu vídeo do banco e do disco.</p>
    <button class="admin-button admin-button--danger" type="submit">Excluir case</button>
  </form>
</AdminLayout>
