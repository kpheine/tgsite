---
import AdminLayout from '../../../components/AdminLayout.astro';
import { adminUrl, isAdminPath, requireUser } from '../../../lib/auth';
import { db, type CaseRecord } from '../../../lib/db';

if (!isAdminPath(Astro.params.adminPath)) {
  return new Response('Não encontrado', { status: 404 });
}

const user = requireUser(Astro.cookies);
if (!user) return Astro.redirect(adminUrl('login'));

const cases = db.prepare('SELECT * FROM cases ORDER BY sort_order ASC, updated_at DESC').all() as CaseRecord[];
const statusLabels = { draft: 'Rascunho', published: 'Publicado' };
---
<AdminLayout title="Cases" email={user.email}>
  <header class="admin-header">
    <div>
      <p class="admin-kicker">Conteúdo do portfólio</p>
      <h1 class="admin-title">Cases</h1>
    </div>
    <a class="admin-button admin-button--primary" href={adminUrl('cases/new')}>Novo case</a>
  </header>

  <section class="admin-table-wrap">
    <table class="admin-table">
      <thead>
        <tr><th>Título</th><th>Cliente</th><th>Status</th><th>Ordem</th><th>Atualizado</th></tr>
      </thead>
      <tbody>
        {cases.length === 0 && <tr><td colspan="5" class="admin-muted">Nenhum case criado ainda.</td></tr>}
        {cases.map((item) => (
          <tr>
            <td><a href={adminUrl(`cases/${item.id}`)}>{item.titulo}</a></td>
            <td>{item.cliente || '-'}</td>
            <td><span class={`admin-status admin-status--${item.status}`}>{statusLabels[item.status]}</span></td>
            <td>{item.sort_order}</td>
            <td>{new Date(item.updated_at).toLocaleDateString('pt-BR')}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</AdminLayout>
