---
import AdminLayout from '../../../components/AdminLayout.astro';
import { adminUrl, isAdminPath, requireUser } from '../../../lib/auth';
import { db, type CaseRecord } from '../../../lib/db';

if (!isAdminPath(Astro.params.adminPath)) {
  return new Response('Não encontrado', { status: 404 });
}

const user = requireUser(Astro.cookies);
if (!user) return Astro.redirect(adminUrl('login'));

const cases = db.prepare('SELECT * FROM cases ORDER BY sort_order DESC, id DESC').all() as CaseRecord[];
const statusLabels = { draft: 'Rascunho', published: 'Publicado' };
---
<AdminLayout title="Cases" username={user.username}>
  <header class="admin-header">
    <div>
      <p class="admin-kicker">Conteúdo do portfólio</p>
      <h1 class="admin-title">Cases</h1>
    </div>
    <a class="admin-button admin-button--primary" href={adminUrl('cases/new')}>Novo case</a>
  </header>

  <section class="admin-case-order-panel" data-case-order-panel>
    <div class="admin-case-order-panel__header">
      <p class="admin-muted">Arraste os cards para definir a ordem de exibição. Novos cases entram no topo automaticamente.</p>
      <p class="admin-muted" data-case-order-status aria-live="polite"></p>
    </div>

    {cases.length === 0 && <p class="admin-muted">Nenhum case criado ainda.</p>}
    <div class="admin-case-list" data-case-order-list>
      {cases.map((item) => (
        <article class="admin-case-card" data-case-card data-case-id={item.id} draggable="true">
          <div class="admin-case-card__topline">
            <span class="admin-drag-handle" aria-hidden="true">Arraste</span>
            <span class={`admin-status admin-status--${item.status}`}>{statusLabels[item.status]}</span>
          </div>
          <div class="admin-case-card__content">
            <h2>{item.titulo}</h2>
            <p>{item.cliente || 'Sem cliente informado'}</p>
          </div>
          <div class="admin-case-card__footer">
            <span>Atualizado em {new Date(item.updated_at).toLocaleDateString('pt-BR')}</span>
            <a href={adminUrl(`cases/${item.id}`)}>Editar</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</AdminLayout>
