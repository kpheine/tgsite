---
import AdminLayout from '../../../components/AdminLayout.astro';
import { adminUrl, isAdminPath, requireUser } from '../../../lib/auth';
import { db, type ProjectRecord } from '../../../lib/db';

if (!isAdminPath(Astro.params.adminPath)) {
  return new Response('Not found', { status: 404 });
}

const user = requireUser(Astro.cookies);
if (!user) return Astro.redirect(adminUrl('login'));

const projects = db.prepare('SELECT * FROM projects ORDER BY sort_order ASC, updated_at DESC').all() as ProjectRecord[];
---
<AdminLayout title="Projects" email={user.email}>
  <header class="admin-header">
    <div>
      <p class="admin-kicker">Portfolio content</p>
      <h1 class="admin-title">Projects</h1>
    </div>
    <a class="admin-button admin-button--primary" href={adminUrl('projects/new')}>New project</a>
  </header>

  <section class="admin-table-wrap">
    <table class="admin-table">
      <thead>
        <tr><th>Title</th><th>Client</th><th>Status</th><th>Order</th><th>Updated</th></tr>
      </thead>
      <tbody>
        {projects.length === 0 && <tr><td colspan="5" class="admin-muted">No projects created yet.</td></tr>}
        {projects.map((project) => (
          <tr>
            <td><a href={adminUrl(`projects/${project.id}`)}>{project.title}</a><br /><span class="admin-muted">/{project.slug}</span></td>
            <td>{project.client || '-'}</td>
            <td><span class={`admin-status admin-status--${project.status}`}>{project.status}</span></td>
            <td>{project.sort_order}</td>
            <td>{new Date(project.updated_at).toLocaleDateString('pt-BR')}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</AdminLayout>
