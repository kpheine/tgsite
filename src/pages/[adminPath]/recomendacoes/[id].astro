---
import AdminLayout from '../../../components/AdminLayout.astro';
import AdminTestimonialForm from '../../../components/AdminTestimonialForm.astro';
import { adminUrl, isAdminPath, requireUser } from '../../../lib/auth';
import { db, type TestimonialRecord } from '../../../lib/db';

if (!isAdminPath(Astro.params.adminPath)) {
  return new Response('Não encontrado', { status: 404 });
}

const user = requireUser(Astro.cookies);
if (!user) return Astro.redirect(adminUrl('login'));

const item = db.prepare('SELECT * FROM testimonials WHERE id = ?').get(Astro.params.id) as TestimonialRecord | undefined;
if (!item) return new Response('Não encontrado', { status: 404 });
---
<AdminLayout title={`Editar ${item.title}`} username={user.username}>
  <header class="admin-header">
    <div>
      <p class="admin-kicker">Editar depoimento</p>
      <h1 class="admin-title">{item.title}</h1>
    </div>
  </header>

  <AdminTestimonialForm item={item} />

  <form class="admin-form admin-form--delete" method="post" action={`/api/panel/testimonials/${item.id}`} data-testimonial-delete-form>
    <input type="hidden" name="_action" value="delete" />
    <p class="admin-muted">Excluir remove a recomendação do painel e do site.</p>
    <button class="admin-button admin-button--danger" type="submit">Excluir recomendação</button>
  </form>
</AdminLayout>
