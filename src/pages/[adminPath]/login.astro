---
import { adminUrl, getCurrentUser, isAdminPath } from '../../lib/auth';

if (!isAdminPath(Astro.params.adminPath)) {
  return new Response('Not found', { status: 404 });
}

if (getCurrentUser(Astro.cookies)) {
  return Astro.redirect(adminUrl());
}

const error = Astro.url.searchParams.get('error');
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login | TG Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main class="login-page">
      <form class="login-card" method="post" action="/api/panel/login">
        <input type="hidden" name="adminPath" value={Astro.params.adminPath} />
        <p class="login-kicker">Private area</p>
        <h1>TG Admin</h1>
        {error && <p class="login-error">Invalid email or password.</p>}
        <label>
          Email
          <input name="email" type="email" autocomplete="email" required />
        </label>
        <label>
          Password
          <input name="password" type="password" autocomplete="current-password" required />
        </label>
        <button type="submit">Sign in</button>
      </form>
    </main>
  </body>
</html>

<style>
  * { box-sizing: border-box; }
  body { margin: 0; font-family: Inter, system-ui, sans-serif; background: radial-gradient(circle at top, rgba(103, 137, 217, 0.22), transparent 35%), #090909; color: #fff; }
  .login-page { align-items: center; display: flex; min-height: 100dvh; justify-content: center; padding: 24px; }
  .login-card { width: min(100%, 420px); border: 1px solid rgba(255, 255, 255, 0.14); border-radius: 28px; background: linear-gradient(145deg, rgba(28, 28, 28, 0.96), rgba(10, 10, 10, 0.96)); box-shadow: 0 24px 80px rgba(0, 0, 0, 0.35); display: grid; gap: 18px; padding: 34px; }
  .login-kicker { color: #8fa8ff; font-size: 12px; font-weight: 700; letter-spacing: 0.14em; margin: 0; text-transform: uppercase; }
  h1 { font-family: 'Bebas Neue', sans-serif; font-size: 64px; font-weight: 400; line-height: 0.9; margin: 0 0 8px; }
  label { color: #aaa; display: grid; font-size: 13px; font-weight: 700; gap: 8px; text-transform: uppercase; }
  input { border: 1px solid rgba(255, 255, 255, 0.14); border-radius: 14px; background: rgba(255, 255, 255, 0.05); color: #fff; font: 400 16px/1.4 Inter, system-ui, sans-serif; padding: 14px 16px; }
  button { border: 0; border-radius: 999px; background: linear-gradient(135deg, #6789d9, #b7c8ff); color: #080808; cursor: pointer; font: 800 13px/1 Inter, system-ui, sans-serif; padding: 16px; text-transform: uppercase; }
  .login-error { border: 1px solid rgba(255, 117, 117, 0.45); border-radius: 14px; color: #ff7575; margin: 0; padding: 12px 14px; }
</style>
