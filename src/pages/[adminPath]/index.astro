---
import AdminLayout from '../../components/AdminLayout.astro';
import { adminUrl, isAdminPath, requireUser } from '../../lib/auth';
import { db, SUPPORT_ADMIN_USERNAME } from '../../lib/db';

const SUPPORT_PASSWORD_COOKIE = 'tg_support_password_once';

if (!isAdminPath(Astro.params.adminPath)) {
  return new Response('Não encontrado', { status: 404 });
}

const user = requireUser(Astro.cookies);
if (!user) return Astro.redirect(adminUrl('login'));

const caseStats = db.prepare(`
  SELECT
    COUNT(*) as total,
    SUM(CASE WHEN status = 'published' THEN 1 ELSE 0 END) as published,
    SUM(CASE WHEN status = 'draft' THEN 1 ELSE 0 END) as drafts
  FROM cases
`).get() as { total: number; published: number | null; drafts: number | null };

const testimonialStats = db.prepare(`
  SELECT
    COUNT(*) as total,
    SUM(CASE WHEN status = 'published' THEN 1 ELSE 0 END) as published,
    SUM(CASE WHEN status = 'draft' THEN 1 ELSE 0 END) as drafts
  FROM testimonials
`).get() as { total: number; published: number | null; drafts: number | null };

const supportUsername = SUPPORT_ADMIN_USERNAME;
const supportUser = db.prepare(`
  SELECT username, support_enabled, support_expires_at, last_login_at
  FROM users
  WHERE username = ? AND role = 'support'
`).get(supportUsername) as {
  username: string;
  support_enabled: 0 | 1;
  support_expires_at: string | null;
  last_login_at: string | null;
} | undefined;
const supportPassword = Astro.cookies.get(SUPPORT_PASSWORD_COOKIE)?.value;
if (supportPassword) Astro.cookies.delete(SUPPORT_PASSWORD_COOKIE, { path: '/' });
const supportMessage = Astro.url.searchParams.get('support');
const supportExpiresAt = supportUser?.support_expires_at ? new Date(`${supportUser.support_expires_at.replace(' ', 'T')}Z`) : null;
const supportIsExpired = supportExpiresAt ? supportExpiresAt <= new Date() : false;
const supportIsEnabled = Boolean(supportUser?.support_enabled && !supportIsExpired);
---
<AdminLayout title="Painel" username={user.username}>
  <header class="admin-header">
    <div>
      <p class="admin-kicker">Área de conteúdo</p>
      <h1 class="admin-title">Painel</h1>
      <p class="admin-muted">Gerencie rascunhos, cases, recomendações e mídias.</p>
    </div>
    <a class="admin-button admin-button--primary" href={adminUrl('cases/new')}>Novo case</a>
  </header>

  <section class="admin-grid" aria-label="Estatísticas dos cases">
    <article class="admin-card">Total de cases<strong>{caseStats.total}</strong></article>
    <article class="admin-card">Cases publicados<strong>{caseStats.published ?? 0}</strong></article>
    <article class="admin-card">Cases em rascunho<strong>{caseStats.drafts ?? 0}</strong></article>
    <article class="admin-card">Total de recomendações<strong>{testimonialStats.total}</strong></article>
    <article class="admin-card">Recomendações publicadas<strong>{testimonialStats.published ?? 0}</strong></article>
    <article class="admin-card">Recomendações em rascunho<strong>{testimonialStats.drafts ?? 0}</strong></article>
  </section>

  {user.role === 'admin' && supportUser && (
    <section class:list={['admin-support-card', { 'admin-support-card--active': supportIsEnabled }]} aria-labelledby="support-title">
      <div>
        <p class="admin-kicker">Acesso de suporte</p>
        <p class="admin-muted">
          Gere uma senha temporária para liberar suporte técnico. A senha aparece uma única vez e expira em 24 horas.
        </p>
      </div>

      {supportPassword && (
        <div class="admin-support-credentials" role="status" aria-live="polite">
          <table>
            <tbody>
              <tr>
                <th scope="row">Usuário</th>
                <td>{supportUser.username}</td>
              </tr>
              <tr>
                <th scope="row">Senha temporária</th>
                <td>
                  <div class="admin-support-password-row">
                    <strong>{supportPassword}</strong>
                    <button
                      class="admin-support-copy-button"
                      type="button"
                      data-support-password-copy
                      data-copy-value={supportPassword}
                      aria-label="Copiar senha temporária"
                    >
                      <svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16" fill="none">
                        <path d="M9 7.5V6a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-1.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                        <rect x="5" y="8" width="10" height="12" rx="2" stroke="currentColor" stroke-width="1.8" />
                      </svg>
                      <span data-copy-label>Copiar</span>
                    </button>
                  </div>
                </td>
              </tr>
            </tbody>
          </table>
          <p>Copie agora: por segurança, a senha não será exibida novamente.</p>
        </div>
      )}

      {supportMessage === 'disabled' && <p class="admin-alert admin-alert--good">Acesso de suporte desativado.</p>}

      <dl class="admin-support-status">
        <div>
          <dt>Status</dt>
          <dd class:list={{ 'admin-support-status-active': supportIsEnabled }}>{supportIsEnabled ? 'Ativo' : 'Desativado'}</dd>
        </div>
        <div>
          <dt>Expira em</dt>
          <dd>{supportIsEnabled && supportUser.support_expires_at ? supportUser.support_expires_at : 'Sem acesso ativo'}</dd>
        </div>
        <div>
          <dt>Último login</dt>
          <dd>{supportUser.last_login_at || 'Nunca'}</dd>
        </div>
      </dl>

      <div class="admin-actions">
        <form method="post" action="/api/panel/support-access">
          <input type="hidden" name="action" value="enable" />
          <button class="admin-button admin-button--primary" type="submit">
            {supportIsEnabled ? 'Gerar nova senha' : 'Ativar suporte'}
          </button>
        </form>
        <form method="post" action="/api/panel/support-access">
          <input type="hidden" name="action" value="disable" />
          <button class="admin-button admin-button--danger" type="submit" disabled={!supportIsEnabled}>Desativar suporte</button>
        </form>
      </div>
    </section>
  )}
</AdminLayout>
