---
import AdminLayout from '../../components/AdminLayout.astro';
import { adminUrl, isAdminPath, requireUser } from '../../lib/auth';
import { db } from '../../lib/db';

if (!isAdminPath(Astro.params.adminPath)) {
  return new Response('Não encontrado', { status: 404 });
}

const user = requireUser(Astro.cookies);
if (!user) return Astro.redirect(adminUrl('login'));

const stats = db.prepare(`
  SELECT
    COUNT(*) as total,
    SUM(CASE WHEN status = 'published' THEN 1 ELSE 0 END) as published,
    SUM(CASE WHEN status = 'draft' THEN 1 ELSE 0 END) as drafts
  FROM projects
`).get() as { total: number; published: number | null; drafts: number | null };
---
<AdminLayout title="Painel" email={user.email}>
  <header class="admin-header">
    <div>
      <p class="admin-kicker">Área de conteúdo</p>
      <h1 class="admin-title">Painel</h1>
      <p class="admin-muted">Gerencie rascunhos, projetos e mídias. O site público ainda não está conectado.</p>
    </div>
    <a class="admin-button admin-button--primary" href={adminUrl('projects/new')}>Novo projeto</a>
  </header>

  <section class="admin-grid" aria-label="Estatísticas dos projetos">
    <article class="admin-card">Total de projetos<strong>{stats.total}</strong></article>
    <article class="admin-card">Publicados<strong>{stats.published ?? 0}</strong></article>
    <article class="admin-card">Rascunhos<strong>{stats.drafts ?? 0}</strong></article>
  </section>
</AdminLayout>
