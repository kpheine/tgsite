---
---
<section class="contato-section" id="contato">

  <!-- Contact top area -->
  <div class="contato-top">
    <div class="contato-left">
      <h2 class="contato-title">
        <span class="title-gradient">Aqui tem</span>
        <span class="title-white"> o seu próximo<br />grande projeto.</span>
        <br />
        <span class="title-white">E ele começa agora.</span>
      </h2>

      <div class="contato-actions">
        <button type="button" class="site-button site-button--gradient btn-fale" data-modal-open="contact-modal">Fale com a gente</button>
        <a href="https://wa.me/" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
          <img src="/images/footer/zap.svg" alt="" class="zap-icon" aria-hidden="true" />
        </a>
      </div>
    </div>
  </div>

  <!-- Divider -->
  <hr class="contato-divider" />

  <!-- Map -->
  <div class="contato-map">
    <!-- Decorative gradient blob — upper half in contact area, lower half behind map -->
    <div class="contato-blob" aria-hidden="true">
      <img src="/images/footer/blob.png" alt="" />
    </div>

    <iframe
      class="map-iframe"
      src="https://maps.google.com/maps?q=the+group+Av.+Eng.+Luis+Carlos+Berrini+1700+São+Paulo+SP&t=&z=15&ie=UTF8&iwloc=&output=embed"
      title="Localização TG Agency"
      allowfullscreen
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </div>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-logo">
      <img src="/images/footer/tg-logo.png" alt="TG Agency" class="footer-tg-logo" />
    </div>

    <div class="footer-right">
      <div class="footer-contact">
        <p class="footer-phone">+55 11 5105 3333</p>
        <address class="footer-address">
          Av. Eng. Luis Carlos Berrini, 1700<br />
          16º andar – CEP 04571935<br />
          São Paulo – SP – Brasil
        </address>
      </div>

      <div class="footer-social">
        <a href="https://www.linkedin.com/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-item">
          <img src="/images/footer/social-blob.png" alt="" class="social-item__blob" aria-hidden="true" />
          <img src="/images/footer/linkedin-icon.svg" alt="LinkedIn" class="social-item__icon" />
        </a>
        <a href="#" aria-label="Redes sociais" class="social-item">
          <img src="/images/footer/social-blob.png" alt="" class="social-item__blob" aria-hidden="true" />
          <img src="/images/footer/play-icon.svg" alt="Redes sociais" class="social-item__icon" />
        </a>
      </div>
    </div>
  </footer>

</section>

<style>
  .contato-section {
    position: relative;
    background-color: #0d0d0d;
    background-image: url('/images/degrade-pixels.png');
    background-size: auto;
    background-repeat: repeat-x;
    background-position: 0 center;
    background-blend-mode: hard-light;
    animation: bg-pan-x 240s linear infinite;
    width: 100%;
  }

  /* ── Contact top ─────────────────────────────── */
  .contato-top {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 5rem 165px 0;
    min-height: 520px;
    z-index: 1;
  }

  .contato-left {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding-bottom: 5rem;
    z-index: 1;
  }

  .contato-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5.2vw, 6.25rem);
    font-weight: 400;
    line-height: 1.05;
    text-transform: uppercase;
  }

  .title-gradient {
    background: linear-gradient(
      -84.12deg,
      rgb(234, 14, 129) 5%,
      rgb(163, 67, 203) 83%,
      rgb(87, 112, 225) 93%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .title-white {
    color: #fff;
  }

  .contato-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .btn-fale {
    --site-button-padding: 1.2rem 2.25rem;
    white-space: nowrap;
  }

  .zap-icon {
    width: 44px;
    height: 44px;
    object-fit: contain;
  }

  /* Gradient blob — anchored to top of map, upper half floats into contact area */
  .contato-blob {
    position: absolute;
    right: 165px;
    top: 0;
    transform: translateY(-50%);
    width: 40%;
    z-index: 0;
    pointer-events: none;
  }

  .contato-blob img {
    width: 100%;
    height: auto;
    display: block;
    mix-blend-mode: screen;
  }

  /* ── Divider ─────────────────────────────────── */
  .contato-divider {
    position: relative;
    z-index: 1;
    border: none;
    border-top: 1px solid #fff;
    margin: 30px 165px;
  }

  /* ── Map ─────────────────────────────────────── */
  .contato-map {
    position: relative;
    padding: 0 165px;
  }

  .map-iframe {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 400px;
    border: none;
    border-radius: 16px;
    display: block;
  }

  /* ── Footer ──────────────────────────────────── */
  .site-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2rem 165px 2.5rem;
    gap: 2rem;
  }

  .footer-tg-logo {
    height: 100px;
    width: auto;
    object-fit: contain;
    display: block;
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 1.25rem;
  }

  .footer-contact {
    text-align: right;
  }

  .footer-phone {
    font-family: 'Inter', sans-serif;
    font-size: 1.45rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
  }

  .footer-address {
    font-family: 'Inter', sans-serif;
    font-size: 1.09rem;
    font-weight: 400;
    font-style: normal;
    color: #fff;
    line-height: 1.6;
    margin-top: 0.5rem;
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .social-item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    flex-shrink: 0;
  }

  .social-item__blob {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .social-item__icon {
    position: relative;
    width: 55%;
    height: 55%;
    object-fit: contain;
  }

  @media (max-width: 768px) {
    .contato-top {
      grid-template-columns: 1fr;
      padding: 3.5rem 1.5rem 0;
      min-height: auto;
    }

    .contato-left {
      padding-bottom: 3.5rem;
    }

    .contato-blob {
      right: 1.5rem;
      width: 60%;
    }

    .contato-divider {
      margin: 2rem 1.5rem;
    }

    .contato-map {
      padding: 0 1.5rem;
    }

    .map-iframe {
      height: 280px;
    }

    .site-footer {
      padding: 2rem 1.5rem 2.5rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .footer-right {
      align-items: flex-start;
      width: 100%;
    }

    .footer-contact {
      text-align: left;
    }
  }

</style>
