---
<section class="sobre-clientes" id="clientes">
  <h2 class="sobre-clientes__title">
    <span class="gradient">AQUI TEM</span> marcas que voce confia.
  </h2>

  <p class="sobre-clientes__subtitle">
    Grandes clientes. Conexões reais.<br />
    Resultados que se repetem.
  </p>

  <div class="sobre-clientes__grid">
    <div class="logo-cell"><img src="/images/logos/einstein.png"   alt="Einstein" /></div>
    <div class="logo-cell"><img src="/images/logos/basf.png"       alt="BASF" /></div>
    <div class="logo-cell"><img src="/images/logos/big.png"        alt="BIG" /></div>
    <div class="logo-cell"><img src="/images/logos/boehringer.png" alt="Boehringer Ingelheim" /></div>
    <div class="logo-cell"><img src="/images/logos/vector-1.png"   alt="Cliente" /></div>
    <div class="logo-cell"><img src="/images/logos/claro.png"      alt="Claro" /></div>
    <div class="logo-cell"><img src="/images/logos/coty.png"       alt="Coty" /></div>
    <div class="logo-cell"><img src="/images/logos/edp.png"        alt="EDP" /></div>
    <div class="logo-cell"><img src="/images/logos/eurofarma.png"  alt="Eurofarma" /></div>
    <div class="logo-cell"><img src="/images/logos/group-14.png"   alt="Cliente" /></div>
    <div class="logo-cell"><img src="/images/logos/genie.png"      alt="Genie" /></div>
    <div class="logo-cell"><img src="/images/logos/getinge.png"    alt="Getinge" /></div>
    <div class="logo-cell"><img src="/images/logos/petropolis.png" alt="Grupo Petrópolis" /></div>
    <div class="logo-cell"><img src="/images/logos/marfrig.png"    alt="Marfrig" /></div>
    <div class="logo-cell"><img src="/images/logos/natura.png"     alt="Natura" /></div>
    <div class="logo-cell"><img src="/images/logos/netflix.png"    alt="Netflix" /></div>
    <div class="logo-cell"><img src="/images/logos/nissin.png"     alt="Nissin" /></div>
    <div class="logo-cell"><img src="/images/logos/rd-saude.png"   alt="RD Saúde" /></div>
    <div class="logo-cell"><img src="/images/logos/group.png"      alt="Cliente" /></div>
    <div class="logo-cell"><img src="/images/logos/santander.png"  alt="Santander" /></div>
    <div class="logo-cell"><img src="/images/logos/vivo.png"       alt="Vivo" /></div>
    <div class="logo-cell"><img src="/images/logos/group-16.png"   alt="Cliente" /></div>
    <div class="logo-cell"><img src="/images/logos/vamos.png"      alt="Vamos" /></div>
    <div class="logo-cell"><img src="/images/logos/vortx.png"      alt="Vortx" /></div>
  </div>
</section>

<style>
  .sobre-clientes {
    background-color: #030303;
    background-image: url('/images/degrade-pixels.png');
    background-size: auto;
    background-repeat: repeat-x;
    background-position: 0 center;
    background-blend-mode: hard-light;
    animation: bg-pan-x 240s linear infinite reverse;
    color: #fff;
    padding: 100px 165px;
    text-align: center;
  }

  /* Title */
  .sobre-clientes__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 8vw, 7.5rem);
    line-height: 1.08;
    margin: 0;
    text-transform: uppercase;
  }

  .sobre-clientes__title .gradient {
    background: linear-gradient(
      to right,
      #45abff 0%,
      #bb4fcd 12%,
      #f7d600 31.7%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Subtitle */
  .sobre-clientes__subtitle {
    font-family: 'Figtree', sans-serif;
    font-size: clamp(1.25rem, 3vw, 3.25rem);
    font-weight: 400;
    line-height: 1.3;
    margin: 145px 0 60px;
  }

  /* Logo grid */
  .sobre-clientes__grid {
    display: grid;
    grid-template-columns: repeat(8, minmax(0, 1fr));
    gap: 48px 32px;
    align-items: center;
    justify-items: center;
  }

  .logo-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    width: 100%;
    height: 64px;
    gap: 6px;
  }

  .logo-cell img {
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 48px;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.85;
  }

  @media (max-width: 768px) {
    .sobre-clientes {
      padding: 3.5rem 1.5rem;
    }

    .sobre-clientes__subtitle {
      margin: 2rem 0 2rem;
    }

    .sobre-clientes__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem 0.75rem;
    }

    .logo-cell img {
      max-height: 36px;
    }
  }

  @media (max-width: 400px) {
    .sobre-clientes__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
