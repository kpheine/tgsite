---
import { clientLogos } from '../data/site-content';
---
<section class="sobre-clientes" id="clientes">
  <h2 class="sobre-clientes__title">
    <span class="gradient">AQUI TEM</span> marcas que voce confia.
  </h2>

  <p class="sobre-clientes__subtitle">
    Grandes clientes. Conexões reais.<br />
    Resultados que se repetem.
  </p>

  <div class="sobre-clientes__grid">
    {clientLogos.map((logo) => (
      <div class="logo-cell"><img src={logo.src} alt={logo.alt} /></div>
    ))}
  </div>
</section>

<style>
  .sobre-clientes {
    background-color: #030303;
    background-image: url('/images/degrade-pixels.png');
    background-size: auto;
    background-repeat: repeat-x;
    background-position: 0 center;
    background-blend-mode: hard-light;
    animation: bg-pan-x 240s linear infinite reverse;
    color: #fff;
    padding: 100px 165px;
    text-align: center;
  }

  /* Title */
  .sobre-clientes__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 8vw, 7.5rem);
    line-height: 1.08;
    margin: 0;
    text-transform: uppercase;
  }

  .sobre-clientes__title .gradient {
    background: linear-gradient(
      to right,
      #45abff 0%,
      #bb4fcd 12%,
      #f7d600 31.7%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Subtitle */
  .sobre-clientes__subtitle {
    font-family: 'Figtree', sans-serif;
    font-size: clamp(1.25rem, 3vw, 3.25rem);
    font-weight: 400;
    line-height: 1.3;
    margin: 145px 0 60px;
  }

  /* Logo grid */
  .sobre-clientes__grid {
    display: grid;
    grid-template-columns: repeat(8, minmax(0, 1fr));
    gap: 48px 32px;
    align-items: center;
    justify-items: center;
  }

  .logo-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    width: 100%;
    height: 64px;
    gap: 6px;
  }

  .logo-cell img {
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 48px;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.85;
  }

  @media (max-width: 768px) {
    .sobre-clientes {
      padding: 3.5rem 1.5rem;
    }

    .sobre-clientes__subtitle {
      margin: 2rem 0 2rem;
    }

    .sobre-clientes__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem 0.75rem;
    }

    .logo-cell img {
      max-height: 36px;
    }
  }

  @media (max-width: 400px) {
    .sobre-clientes__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
