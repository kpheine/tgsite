---

---

<section class="historia-section" id="historia">
  <!-- Pixel gradient background -->
  <img
    src="/images/historia-bg.png"
    alt=""
    class="historia-bg"
    aria-hidden="true"
  />

  <div class="historia-inner">
    <!-- Left: text content -->
    <div class="historia-text">
      <h2 class="historia-headline">
        <span class="headline-gradient">Aqui tem</span>
        inteligência<br />em escala.
      </h2>

      <p class="historia-anos">mais de 30 anos</p>

      <p class="historia-body">
        transformando estratégia em<br />
        encontros que movem marcas<br />
        com estratégia e precisão.
      </p>

      <a href="/sobre" class="site-button site-button--gradient btn-historia"
        >Conheça nossa história</a
      >
    </div>

    <!-- Right: blob-shaped photo -->
    <div class="historia-photo-wrapper" aria-hidden="true">
      <img
        src="/images/banner_1.png"
        alt="Stand de evento"
        class="historia-photo"
      />
    </div>
  </div>
</section>

<style>
  .historia-section {
    position: relative;
    width: 100%;
    min-height: 100svh;
    background-color: #0d0d0d;
    overflow: hidden;
  }

  /* Pixel gradient background — white-at-top, dark-at-bottom, 80% opacity */
  .historia-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 278%;
    object-fit: cover;
    object-position: top center;
    opacity: 0.8;
    pointer-events: none;
  }

  /* Two-column inner layout */
  .historia-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    min-height: 100svh;
    padding: 5rem 8.4% 5rem;
    gap: 4rem;
  }

  /* ── Text column ─────────────────────────────── */
  .historia-text {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .historia-headline {
    font-family: "Bebas Neue", sans-serif;
    font-size: clamp(4rem, 6.9vw, 8.3rem); /* ~133px at 1920px */
    font-weight: 400;
    line-height: 1;
    color: #fff;
    text-transform: uppercase;
  }

  .headline-gradient {
    display: block;
    background: linear-gradient(
      -86.48deg,
      rgb(33, 110, 242) 4.82%,
      rgb(163, 67, 203) 75.93%,
      rgb(234, 14, 129) 93.39%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .historia-anos {
    font-family: "Bebas Neue", sans-serif;
    font-size: clamp(2.5rem, 4.4vw, 5.3rem); /* ~85px at 1920px */
    font-weight: 400;
    line-height: 1;
    color: #fff;
    text-transform: uppercase;
  }

  .historia-body {
    font-family: "Figtree", sans-serif;
    font-size: clamp(1.1rem, 2.5vw, 3rem); /* ~48px at 1920px */
    font-weight: 400;
    line-height: 1.3;
    color: #fff;
  }

  .btn-historia {
    align-self: flex-start;
  }

  /* ── Photo column ────────────────────────────── */
  .historia-photo-wrapper {
    aspect-ratio: 1035 / 922;
    border-radius: 54% 46% 48% 52% / 52% 55% 45% 48%;
    overflow: hidden;
  }

  .historia-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
</style>
