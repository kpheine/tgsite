---
import { clientLogos } from '../data/site-content';
---

<section class="clientes-section" id="clientes">
  <div class="clientes-inner">
    <h2 class="clientes-title">
      <span class="title-gradient">Aqui tem</span>
      <span class="title-white"> marcas que confiam na entrega.</span>
    </h2>

    <div class="logos-grid">
      {clientLogos.map((logo) => (
        <div class="logo-item">
          <img src={logo.src} alt={logo.alt} class="logo-img" />
        </div>
      ))}
    </div>
  </div>

  <!-- Placeholder for Depoimentos (second half) -->
  <slot name="depoimentos" />
</section>

<style>
  .clientes-section {
    background-color: #030303;
    background-image: url('/images/degrade-pixels.png');
    background-size: auto;
    background-repeat: repeat-x;
    background-position: 0 center;
    background-blend-mode: hard-light;
    animation: bg-pan-x 240s linear infinite;
    width: 100%;
  }

  .clientes-inner {
    padding: 5rem 8.4%;
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  /* Title */
  .clientes-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5.2vw, 6.25rem); /* ~100px at 1920px */
    font-weight: 400;
    line-height: 1;
    text-transform: uppercase;
  }

  .title-gradient {
    background: linear-gradient(
      90deg,
      rgb(241, 47, 255) 0%,
      rgb(67, 129, 209) 14%,
      rgb(97, 244, 232) 32%,
      rgb(180, 253, 183) 55%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .title-white {
    color: #fff;
  }

  /* Logos grid — 8 cols × 3 rows */
  .logos-grid {
    display: grid;
    grid-template-columns: repeat(8, minmax(0, 1fr));
    grid-template-rows: repeat(3, auto);
    gap: 2rem 2rem;
    align-items: center;
  }

  .logo-item {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-img {
    height: 48px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.85;
  }

  @media (max-width: 768px) {
    .clientes-inner {
      padding: 3rem 1.5rem;
      gap: 2rem;
    }

    .logos-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem 0.75rem;
    }

    .logo-img {
      height: 32px;
      max-width: 100%;
    }
  }

  @media (max-width: 400px) {
    .logos-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
