---
import CasesCarousel from './CasesCarousel.astro';
---
<section class="cases-section" id="cases">
  <img
    src="/images/cases-bg.png"
    alt=""
    class="cases-bg"
    aria-hidden="true"
  />

  <div class="cases-inner">
    <h2 class="cases-title">Cases</h2>

    <CasesCarousel />
  </div>
</section>

<style>
  .cases-section {
    position: relative;
    width: 100%;
    min-height: 100svh;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .cases-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    pointer-events: none;
  }

  .cases-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    min-height: 100svh;
    padding: clamp(3rem, 6svh, 5rem) 7.9% clamp(3rem, 6svh, 5rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(1.6rem, 3.4svh, 3rem);
  }

  .cases-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 4.875rem; /* 78px */
    font-weight: 400;
    line-height: 1;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    text-align: center;
  }

  @media (max-width: 700px) {
    .cases-section {
      min-height: auto;
      display: block;
    }

    .cases-inner {
      min-height: auto;
      padding: 3rem 1rem 4rem;
      gap: 2rem;
    }
  }
</style>
