---
import AdminCaseImageCard from './AdminCaseImageCard.astro';
import { adminUrl } from '../lib/auth';
import type { CaseImageRecord, CaseRecord } from '../lib/db';
import { formatBytesLabel } from '../lib/bytes';
import { MAX_IMAGE_BYTES } from '../lib/upload-limits';
import { getYouTubeEmbedUrl } from '../lib/youtube';

interface Props {
  item?: CaseRecord;
  images?: CaseImageRecord[];
}

const { item, images = [] } = Astro.props;
const isEdit = Boolean(item);
const action = item ? `/api/panel/cases/${item.id}` : '/api/panel/cases';
const status = item?.status ?? 'draft';
const maxImageLabel = formatBytesLabel(MAX_IMAGE_BYTES);
const videoEmbedUrl = getYouTubeEmbedUrl(item?.video_url);
---

<form class="admin-form" method="post" action={action} enctype="multipart/form-data" data-case-form>
  <div class="admin-form-row">
    <div class="admin-field"><label for="titulo">Título</label><input class="admin-input" id="titulo" name="titulo" value={item?.titulo ?? ''} required /></div>
    <div class="admin-field"><label for="cliente">Cliente</label><input class="admin-input" id="cliente" name="cliente" value={item?.cliente || ''} /></div>
  </div>
  <div class="admin-field" data-status-toggle-field>
    <label for="status">Status</label>
    <input id="status" name="status" type="hidden" value={status} data-status-toggle-input />
    <button class="admin-status-toggle" type="button" data-status-toggle aria-pressed={status === 'published' ? 'true' : 'false'}>
      <span data-status-toggle-label>{status === 'published' ? 'Publicado' : 'Rascunho'}</span>
      <small>Clique aqui para mudar o status</small>
    </button>
  </div>
  <div class="admin-field" data-main-image-upload data-max-image-bytes={MAX_IMAGE_BYTES}>
    <label for="main_image">Imagem principal do case</label>
    {item ? (
      <>
        <div class="admin-main-image-current admin-main-image-current--replace" data-main-image-zone>
          <p class="admin-muted">Imagem principal atual</p>
          <div class="admin-main-image-frame">
            <img src={item.main_image_url} alt="" data-main-image-current-img />
            <button class="admin-main-image-replace" type="button" data-main-image-button>
              Clique aqui ou arraste uma imagem para substituir
            </button>
            <button class="admin-main-image-revert" type="button" data-main-image-revert hidden>
              Reverter troca
            </button>
          </div>
          <input class="admin-file-input" id="main_image" name="main_image" type="file" accept="image/*" data-main-image-input />
        </div>
        <div class="admin-main-image-selection" data-main-image-preview hidden>
          <strong data-main-image-name></strong>
          <span class="admin-muted" data-main-image-size></span>
        </div>
        <p class="admin-alert admin-alert--compact" data-main-image-message hidden></p>
        <p class="admin-muted">Imagem até {maxImageLabel}. A substituição só será aplicada ao salvar alterações.</p>
      </>
    ) : (
      <>
        <div class="admin-upload-zone" data-main-image-zone>
          <input class="admin-file-input" id="main_image" name="main_image" type="file" accept="image/*" required data-main-image-input />
          <div>
            <strong>Solte a imagem principal aqui</strong>
            <p class="admin-muted">Obrigatória, até {maxImageLabel}. Será usada como thumbnail do case fora da galeria.</p>
          </div>
          <button class="admin-button" type="button" data-main-image-button>Selecionar imagem</button>
        </div>
        <p class="admin-alert admin-alert--compact" data-main-image-message hidden></p>
        <div class="admin-main-image-preview" data-main-image-preview hidden>
          <p class="admin-muted">Imagem principal selecionada</p>
          <img src="" alt="" data-main-image-preview-img />
          <strong data-main-image-name></strong>
          <span class="admin-muted" data-main-image-size></span>
        </div>
      </>
    )}
  </div>
  <div class="admin-field" data-youtube-preview>
    <label for="video_url">Vídeo do case</label>
    <input
      class="admin-input"
      id="video_url"
      name="video_url"
      type="text"
      inputmode="url"
      placeholder="https://www.youtube.com/watch?v=... ou O_xQLiBG9KM"
      value={item?.video_url ?? ''}
      data-youtube-url-input
    />
    <p class="admin-muted">Cole uma URL do YouTube. A prévia abaixo confirma se o link está funcionando corretamente.</p>
    <p class="admin-alert admin-alert--compact" data-video-message hidden></p>
    <div class="admin-video-preview" data-video-preview hidden={!videoEmbedUrl}>
      <iframe
        src={videoEmbedUrl ?? undefined}
        title="Prévia do vídeo do YouTube"
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
        data-youtube-preview-frame
      ></iframe>
    </div>
  </div>
  <div class="admin-field"><label for="desafio">Desafio</label><textarea class="admin-textarea" id="desafio" name="desafio">{item?.desafio || ''}</textarea></div>
  <div class="admin-field"><label for="entrega">Entrega</label><textarea class="admin-textarea" id="entrega" name="entrega">{item?.entrega || ''}</textarea></div>
  <div class="admin-field"><label for="resultado">Resultado</label><textarea class="admin-textarea" id="resultado" name="resultado">{item?.resultado || ''}</textarea></div>

  <div class="admin-field" data-image-upload data-max-image-bytes={MAX_IMAGE_BYTES}>
    <label for="images">{isEdit ? 'Adicionar imagens' : 'Imagens do case'}</label>
    <div class="admin-upload-zone" data-upload-zone>
      <input class="admin-file-input" id="images" name="images" type="file" accept="image/*" multiple data-upload-input />
      <div>
        <strong>{isEdit ? 'Solte novas imagens aqui' : 'Solte as imagens aqui'}</strong>
        <p class="admin-muted">{isEdit ? `Imagens até ${maxImageLabel} entram na grade abaixo. Arraste qualquer card para definir a ordem final.` : `Imagens até ${maxImageLabel} aparecem na grade abaixo para remoção e ordenação antes do envio.`}</p>
      </div>
      <button class="admin-button" type="button" data-upload-button>Selecionar imagens</button>
    </div>
    <p class="admin-alert admin-alert--compact" data-upload-message hidden></p>
    <template data-upload-card-template><AdminCaseImageCard mode="upload-template" /></template>
    {isEdit && <label>Imagens do case</label>}
    {isEdit && images.length === 0 && <p class="admin-muted">Nenhuma imagem adicionada ainda.</p>}
    <div class="admin-image-list" data-image-list>
      {images.map((image) => (
        <AdminCaseImageCard mode="existing" id={image.id} url={image.url} destaque={image.destaque === 1} order={image.sort_order} />
      ))}
    </div>
  </div>
  {!isEdit && <p class="admin-muted">Depois de selecionar as imagens, arraste os cards para definir a ordem de exibição.</p>}
  <div class="admin-actions">
    <button class="admin-button admin-button--primary" type="submit">{isEdit ? 'Salvar alterações' : 'Criar case'}</button>
    <a class="admin-button" href={adminUrl('cases')}>{isEdit ? 'Voltar' : 'Cancelar'}</a>
  </div>
</form>
