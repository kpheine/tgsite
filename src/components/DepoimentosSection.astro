---
import { getPublicTestimonials } from '../lib/public-testimonials';

const fallbackCards = [
  {
    title: "Título aqui",
    quote: '"This summit opened my eyes to the future of AI and how it will shape industries."',
    personName: "Nome Sobrenome",
    personRole: "Marketing, BASF",
  },
  {
    title: "Título aqui",
    quote: '"Incredible speakers, top-tier networking, and cutting-edge discussions all in one place."',
    personName: "Nome Sobrenome",
    personRole: "Marketing, EDP",
  },
  {
    title: "Título aqui",
    quote: '"From hands-on workshops to visionary talks, this summit is a must-attend for AI professionals."',
    personName: "Nome Sobrenome",
    personRole: "Marketing, Volkswagen",
  },
  {
    title: "Título aqui",
    quote: '"An unforgettable experience that challenged everything we thought we knew about strategy."',
    personName: "Nome Sobrenome",
    personRole: "Marketing, Claro",
  },
  {
    title: "Título aqui",
    quote: '"The connections made here translated directly into business results within months."',
    personName: "Nome Sobrenome",
    personRole: "Marketing, Natura",
  },
];

const variants = ['sunset', 'blue', 'pink'];
const publicTestimonials = getPublicTestimonials();
const cards = (publicTestimonials.length > 0 ? publicTestimonials : fallbackCards).map((card, index) => ({
  ...card,
  variant: variants[index % variants.length],
}));
---

<div class="dep-section" id="depoimentos">
  <div class="dep-inner">
    <!-- Title + nav row -->
    <div class="dep-header">
      <h2 class="dep-title">
        <span class="dep-gradient">Aqui tem</span>
        <span class="dep-white"> quem recomenda.</span>
      </h2>

      <div class="dep-nav">
        <button class="nav-btn nav-prev" aria-label="Anterior">
          <img src="/images/arrow-left.svg" alt="" aria-hidden="true" />
        </button>
        <button class="nav-btn nav-next" aria-label="Próximo">
          <img src="/images/arrow-right.svg" alt="" aria-hidden="true" />
        </button>
      </div>
    </div>

    <!-- Carousel viewport -->
      <div class="carousel-viewport">
        <div class:list={['carousel-track', { 'carousel-track--centered': cards.length < 3 }]} id="dep-track">
        {cards.map((card) => (
          <div class:list={['dep-card', `dep-card--${card.variant}`]}>
            <h3 class="card-title">{card.title}</h3>
            <p class="card-quote">{card.quote}</p>
            <div class="card-attr">
              <p class="card-name">{card.personName}</p>
              <p class="card-role">{card.personRole}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .dep-section {
    background-color: #030303;
    background-image: url('/images/degrade-pixels.png');
    background-size: auto;
    background-repeat: repeat-x;
    background-position: 0 center;
    background-blend-mode: hard-light;
    animation: bg-pan-x 240s linear infinite reverse;
    width: 100%;
    padding-bottom: 5rem;
  }

  .dep-inner {
    padding: 4rem 8.4% 0;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* Header row */
  .dep-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
  }

  .dep-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5.2vw, 6.25rem);
    font-weight: 400;
    line-height: 1;
    text-transform: uppercase;
  }

  .dep-gradient {
    background: linear-gradient(
      90deg,
      rgb(241, 47, 255) 0%,
      rgb(67, 129, 209) 14%,
      rgb(97, 244, 232) 32%,
      rgb(180, 253, 183) 55%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .dep-white {
    color: #fff;
  }

  /* Nav buttons */
  .dep-nav {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-shrink: 0;
    padding-bottom: 0.25rem;
  }

  .dep-nav.is-hidden {
    display: none;
  }

  .nav-btn {
    position: relative;
    width: 68px;
    height: 68px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.15s ease;
    /* Active: gradient fill */
    background: linear-gradient(-87.39deg, rgb(33,110,242) 5%, rgb(163,67,203) 49%, rgb(234,14,129) 93%);
  }

  .nav-btn[hidden] {
    display: none !important;
  }

  .nav-btn img {
    position: relative;
    z-index: 1;
    width: 28px;
    height: 28px;
    filter: brightness(0) invert(1);
  }

  /* Left arrow: rotate ↗ by -45deg then flip horizontally → ← */
  .nav-prev img {
    transform: rotate(-45deg) scaleX(-1);
  }

  /* Right arrow: rotate ↗ by 45deg → → */
  .nav-next img {
    transform: rotate(45deg);
  }

  .nav-btn:hover:not(:disabled) {
    opacity: 0.8;
  }

  /* Inactive: transparent bg + gradient border via mask */
  .nav-btn:disabled {
    background: transparent;
    cursor: default;
  }

  .nav-btn:disabled::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    padding: 2px;
    background: linear-gradient(-87.39deg, rgb(33,110,242) 5%, rgb(163,67,203) 49%, rgb(234,14,129) 93%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
  }

  /* Carousel */
  .carousel-viewport {
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    gap: 1.25rem;
    transition: transform 0.4s ease;
    will-change: transform;
  }

  @media (min-width: 769px) {
    .carousel-track--centered {
      justify-content: center;
    }
  }

  /* Cards — 3 visible at once on desktop, 1 on mobile */
  .dep-card {
    flex: 0 0 calc((100% - 2 * 1.25rem) / 3);
    border-radius: 46px;
    padding: 2.5rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-height: 307px;
  }

  .dep-card--sunset {
    background: linear-gradient(-51.34deg, rgb(120, 30, 135) 0%, rgb(191, 27, 145) 22%, rgb(242, 137, 0) 96%, rgb(247, 214, 0) 121%);
  }

  .dep-card--blue {
    background: linear-gradient(-68.78deg, rgb(33, 110, 242) 22%, rgb(163, 67, 203) 62%, rgb(234, 14, 129) 89%);
  }

  .dep-card--pink {
    background: linear-gradient(117.28deg, rgb(33, 110, 242) 30%, rgb(163, 67, 203) 73%, rgb(234, 14, 129) 94%);
  }

  .card-title {
    font-family: 'Inter', sans-serif;
    font-size: 1.74rem;
    font-weight: 700;
    line-height: 1.2;
    color: #fff;
    text-transform: uppercase;
  }

  .card-quote {
    font-family: 'Inter', sans-serif;
    font-size: 1.16rem;
    font-weight: 400;
    line-height: 1.5;
    color: #fff;
    flex: 1;
  }

  .card-attr {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .card-name,
  .card-role {
    font-family: 'Inter', sans-serif;
    font-size: 1.04rem;
    font-weight: 400;
    color: #fff;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .dep-inner {
      padding: 3rem 1.5rem 0;
      gap: 1.75rem;
    }

    .dep-card {
      flex: 0 0 100%;
      min-height: auto;
      border-radius: 28px;
    }
  }
</style>

<script>
  const track = document.getElementById('dep-track') as HTMLElement;
  const prevBtn = document.querySelector('.nav-prev') as HTMLButtonElement;
  const nextBtn = document.querySelector('.nav-next') as HTMLButtonElement;

  const cards = track.querySelectorAll('.dep-card');
  const total = cards.length;
  let current = 0;

  function getVisible() {
    return window.innerWidth <= 768 ? 1 : 3;
  }

  function updateCarousel() {
    const visible = getVisible();
    const maxIndex = Math.max(0, total - visible);
    if (current > maxIndex) current = maxIndex;
    const cardWidth = (track.parentElement as HTMLElement).offsetWidth;
    const gap = 20; // 1.25rem at 16px
    const step = (cardWidth + gap) / visible;
    track.style.transform = `translateX(-${current * step}px)`;
    prevBtn.disabled = current === 0;
    nextBtn.disabled = current >= maxIndex;
    prevBtn.hidden = maxIndex === 0;
    nextBtn.hidden = maxIndex === 0;
    prevBtn.parentElement?.classList.toggle('is-hidden', maxIndex === 0);
  }

  prevBtn.addEventListener('click', () => {
    if (current > 0) { current--; updateCarousel(); }
  });

  nextBtn.addEventListener('click', () => {
    const maxIndex = Math.max(0, total - getVisible());
    if (current < maxIndex) { current++; updateCarousel(); }
  });

  window.addEventListener('resize', () => { current = 0; updateCarousel(); });
  updateCarousel();
</script>
