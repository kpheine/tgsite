---
import { adminUrl } from '../lib/auth';

interface Props {
  title: string;
  username?: string;
}

const { title, username } = Astro.props;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | TG Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="admin-shell">
    <aside class="admin-sidebar">
      <a class="admin-brand" href={adminUrl()}>TG Admin</a>
      <nav class="admin-nav" aria-label="Navegação do painel administrativo">
        <a href={adminUrl()}>Painel</a>
        <a href={adminUrl('cases')}>Cases</a>
      </nav>
      {username && <p class="admin-user">Conectado como<br /><strong>{username}</strong></p>}
      {username && (
        <form method="post" action="/api/panel/logout">
          <button class="admin-logout" type="submit">Sair</button>
        </form>
      )}
    </aside>
    <main class="admin-main">
      <slot />
    </main>
    <div class="admin-upload-modal" data-case-upload-modal hidden aria-live="polite" aria-modal="true" role="dialog">
      <div class="admin-upload-modal__card">
        <div class="admin-upload-progress" data-upload-progress-ring style="--upload-progress: 0%;">
          <div class="admin-upload-progress__inner">
            <strong data-upload-progress-percent>0%</strong>
          </div>
        </div>
        <div class="admin-upload-modal__copy">
          <h2 data-upload-progress-title>Enviando arquivos</h2>
          <p data-upload-progress-message>Não feche esta página até o envio terminar.</p>
        </div>
        <button class="admin-button" type="button" data-upload-progress-close hidden>Fechar</button>
      </div>
    </div>
    <script>
      import '../scripts/admin-main-image-upload';
      import '../scripts/admin-image-upload';
      import '../scripts/admin-case-order';
      import '../scripts/admin-case-status-toggle';
      import '../scripts/admin-video-upload';
      import '../scripts/admin-case-form-submit';
      import '../scripts/admin-unsaved-case-warning';
      import '../scripts/admin-case-delete-confirm';
    </script>
  </body>
</html>

<style is:global>
  :root {
    --admin-bg: #090909;
    --admin-panel: #141414;
    --admin-panel-2: #1c1c1c;
    --admin-line: rgba(255, 255, 255, 0.12);
    --admin-text: #f4f4f4;
    --admin-muted: #a8a8a8;
    --admin-accent: #8fa8ff;
    --admin-good: #a7ff83;
    --admin-danger: #ff7575;
  }

  * { box-sizing: border-box; }
  body.admin-shell {
    margin: 0;
    min-height: 100dvh;
    display: grid;
    grid-template-columns: 260px minmax(0, 1fr);
    background: radial-gradient(circle at top right, rgba(103, 137, 217, 0.18), transparent 34%), var(--admin-bg);
    color: var(--admin-text);
    font-family: Inter, system-ui, sans-serif;
  }

  .admin-sidebar {
    position: sticky;
    top: 0;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    gap: 24px;
    border-right: 1px solid var(--admin-line);
    background: rgba(12, 12, 12, 0.92);
    padding: 28px;
  }

  .admin-brand {
    color: #fff;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 42px;
    letter-spacing: 0.04em;
    text-decoration: none;
  }

  .admin-nav { display: grid; gap: 10px; }
  .admin-nav a, .admin-button, .admin-logout {
    border: 1px solid var(--admin-line);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--admin-text);
    cursor: pointer;
    font: 700 13px/1 Inter, system-ui, sans-serif;
    padding: 13px 16px;
    text-align: center;
    text-decoration: none;
    text-transform: uppercase;
  }

  .admin-nav a:hover, .admin-button:hover, .admin-logout:hover { border-color: var(--admin-accent); }
  .admin-button:disabled { cursor: not-allowed; opacity: 0.48; }
  .admin-button--primary { background: linear-gradient(135deg, #6789d9, #b7c8ff); color: #080808; }
  .admin-button--danger { border-color: rgba(255, 117, 117, 0.45); color: var(--admin-danger); }

  .admin-user {
    margin-top: auto;
    color: var(--admin-muted);
    font-size: 13px;
    line-height: 1.5;
  }

  .admin-logout { width: 100%; }
  .admin-main { min-width: 0; padding: 42px; }
  .admin-header { display: flex; align-items: flex-end; justify-content: space-between; gap: 20px; margin-bottom: 28px; }
  .admin-kicker { color: var(--admin-accent); font-size: 12px; font-weight: 700; letter-spacing: 0.12em; margin: 0 0 8px; text-transform: uppercase; }
  .admin-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(44px, 6vw, 72px); font-weight: 400; letter-spacing: 0.02em; line-height: 0.9; margin: 0; }
  .admin-muted { color: var(--admin-muted); }
  .admin-grid { display: grid; gap: 18px; grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .admin-card, .admin-form, .admin-table-wrap, .admin-case-order-panel, .admin-support-card {
    border: 1px solid var(--admin-line);
    border-radius: 24px;
    background: linear-gradient(145deg, rgba(28, 28, 28, 0.92), rgba(12, 12, 12, 0.92));
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
    padding: 24px;
  }
  .admin-card strong { display: block; font-size: 40px; margin-top: 10px; }
  .admin-support-card { display: grid; gap: 20px; margin-top: 24px; max-width: 980px; }
  .admin-support-card h2 { color: #fff; font-size: 28px; margin: 0 0 8px; }
  .admin-support-password { border: 1px solid rgba(167, 255, 131, 0.5); border-radius: 18px; background: rgba(167, 255, 131, 0.08); display: grid; gap: 8px; padding: 18px; }
  .admin-support-password span { color: var(--admin-good); font-size: 12px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; }
  .admin-support-password strong { color: #fff; font: 800 24px/1.2 Inter, system-ui, sans-serif; letter-spacing: 0.04em; overflow-wrap: anywhere; }
  .admin-support-password p { color: var(--admin-muted); margin: 0; }
  .admin-support-status { display: grid; gap: 12px; grid-template-columns: repeat(3, minmax(0, 1fr)); margin: 0; }
  .admin-support-status div { border: 1px solid var(--admin-line); border-radius: 16px; padding: 14px; }
  .admin-support-status dt { color: var(--admin-muted); font-size: 12px; font-weight: 800; margin-bottom: 8px; text-transform: uppercase; }
  .admin-support-status dd { color: #fff; margin: 0; overflow-wrap: anywhere; }
  .admin-table { border-collapse: collapse; width: 100%; }
  .admin-table th, .admin-table td { border-bottom: 1px solid var(--admin-line); padding: 15px 12px; text-align: left; vertical-align: top; }
  .admin-table th { color: var(--admin-muted); font-size: 12px; text-transform: uppercase; }
  .admin-table a { color: #fff; font-weight: 700; }
  .admin-case-order-panel { display: grid; gap: 18px; }
  .admin-case-order-panel__header { align-items: flex-start; display: flex; gap: 16px; justify-content: space-between; }
  .admin-case-order-panel__header p { margin: 0; }
  .admin-case-list { display: grid; gap: 14px; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }
  .admin-case-card {
    background: rgba(255, 255, 255, 0.04);
    aspect-ratio: 1 / 1;
    border: 1px solid var(--admin-line);
    border-radius: 18px;
    cursor: grab;
    display: grid;
    gap: 16px;
    grid-template-rows: auto minmax(0, 1fr) auto;
    min-height: 220px;
    overflow: hidden;
    padding: 16px;
    position: relative;
    transition: border-color 160ms ease, opacity 160ms ease, transform 160ms ease;
  }
  .admin-case-card:hover { border-color: rgba(143, 168, 255, 0.48); }
  .admin-case-card.is-dragging { border-color: var(--admin-accent); cursor: grabbing; opacity: 0.55; }
  .admin-case-card__topline, .admin-case-card__footer { align-items: center; display: flex; gap: 10px; justify-content: space-between; }
  .admin-case-card__content { align-self: center; display: grid; gap: 10px; min-height: 0; min-width: 0; }
  .admin-case-card h2 {
    color: #fff;
    display: -webkit-box;
    font-size: clamp(20px, 2vw, 28px);
    line-height: 1.05;
    margin: 0;
    overflow: hidden;
    overflow-wrap: anywhere;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 4;
  }
  .admin-case-card p {
    color: var(--admin-muted);
    display: -webkit-box;
    font-size: 14px;
    line-height: 1.35;
    margin: 0;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }
  .admin-case-card__footer { color: var(--admin-muted); font-size: 12px; line-height: 1.35; }
  .admin-case-card__footer a { color: var(--admin-accent); font-weight: 800; text-transform: uppercase; }
  .admin-status { border-radius: 999px; display: inline-flex; font-size: 12px; font-weight: 700; padding: 6px 10px; text-transform: uppercase; }
  .admin-status--published { background: rgba(167, 255, 131, 0.12); color: var(--admin-good); }
  .admin-status--draft { background: rgba(255, 255, 255, 0.08); color: var(--admin-muted); }
  .admin-status-toggle {
    border: 1px solid var(--admin-line);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--admin-muted);
    cursor: pointer;
    font: 800 14px/1 Inter, system-ui, sans-serif;
    letter-spacing: 0.08em;
    padding: 17px 18px;
    text-align: center;
    text-transform: uppercase;
    transition: background-color 160ms ease, border-color 160ms ease, color 160ms ease;
    width: 100%;
  }
  .admin-status-toggle[aria-pressed="true"] { background: rgba(167, 255, 131, 0.12); border-color: rgba(167, 255, 131, 0.55); color: var(--admin-good); }
  .admin-status-toggle:hover { border-color: var(--admin-accent); }
  .admin-form { display: grid; gap: 18px; max-width: 980px; }
  .admin-form-row { display: grid; gap: 18px; grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .admin-form-row--compact { align-items: end; grid-template-columns: minmax(0, 1fr) auto; }
  .admin-field { display: grid; gap: 8px; }
  .admin-field label { color: var(--admin-muted); font-size: 13px; font-weight: 700; text-transform: uppercase; }
  .admin-input, .admin-textarea, .admin-select {
    width: 100%;
    border: 1px solid var(--admin-line);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.04);
    color: #fff;
    font: 400 15px/1.4 Inter, system-ui, sans-serif;
    padding: 14px 16px;
  }
  .admin-textarea { min-height: 180px; resize: vertical; }
  .admin-actions { display: flex; flex-wrap: wrap; gap: 12px; }
  .admin-media-list { display: flex; flex-wrap: wrap; gap: 10px; margin: 0; padding: 0; }
  .admin-media-list li { list-style: none; }
  .admin-media-list a { color: var(--admin-accent); }
  .admin-image-list, .admin-upload-list { display: grid; gap: 14px; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }
  .admin-case-image-card {
    border: 1px solid var(--admin-line);
    border-radius: 18px;
    cursor: grab;
    display: grid;
    gap: 12px;
    overflow: hidden;
    padding: 12px;
    position: relative;
    transition: border-color 160ms ease, opacity 160ms ease, transform 160ms ease;
  }
  .admin-case-card__thumb { inset: 0; position: absolute; z-index: 0; }
  .admin-case-card__thumb img { display: block; height: 100%; object-fit: cover; object-position: center; width: 100%; }
  .admin-case-card__thumb::after { background: linear-gradient(180deg, rgba(0, 0, 0, 0.64), rgba(0, 0, 0, 0.88)); content: ''; inset: 0; position: absolute; }
  .admin-case-card__topline, .admin-case-card__content, .admin-case-card__footer { position: relative; z-index: 1; }
  .admin-case-image-card.is-featured { border-color: #f4d94e; box-shadow: 0 0 0 1px rgba(244, 217, 78, 0.35); }
  .admin-case-image-card.is-removing { border-color: rgba(255, 117, 117, 0.7); opacity: 0.72; }
  .admin-case-image-card.is-dragging { border-color: var(--admin-accent); cursor: grabbing; opacity: 0.55; }
  .admin-case-image-card img { aspect-ratio: 16 / 10; border-radius: 12px; display: block; object-fit: cover; width: 100%; }
  .admin-case-image-card__banner {
    background: rgba(143, 168, 255, 0.92);
    border-radius: 999px;
    color: #070707;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1;
    padding: 7px 10px;
    position: absolute;
    right: 10px;
    text-transform: uppercase;
    top: 10px;
    z-index: 1;
  }
  .admin-case-image-card.is-removing .admin-case-image-card__banner { background: rgba(255, 117, 117, 0.96); }
  .admin-case-image-card__meta { display: grid; gap: 5px; min-width: 0; }
  .admin-case-image-card__meta strong { color: #fff; font-size: 13px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .admin-case-image-card__actions { display: flex; flex-wrap: wrap; gap: 8px; }
  .admin-image-action {
    border: 1px solid var(--admin-line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--admin-text);
    cursor: pointer;
    font: 800 12px/1 Inter, system-ui, sans-serif;
    padding: 9px 12px;
    text-transform: uppercase;
  }
  .admin-image-action--feature.is-active { border-color: #f4d94e; color: #f4d94e; }
  .admin-image-action--remove { border-color: rgba(255, 117, 117, 0.5); color: var(--admin-danger); }
  .admin-image-action--restore { border-color: rgba(167, 255, 131, 0.5); color: var(--admin-good); }
  .admin-drag-handle { color: var(--admin-accent); font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
  .admin-file-input { height: 1px; opacity: 0; overflow: hidden; position: absolute; width: 1px; }
  .admin-main-image-current, .admin-main-image-preview {
    border: 1px solid var(--admin-line);
    border-radius: 18px;
    display: grid;
    gap: 12px;
    overflow: hidden;
    padding: 12px;
  }
  .admin-main-image-frame { aspect-ratio: 16 / 10; border-radius: 12px; overflow: hidden; position: relative; }
  .admin-main-image-current img, .admin-main-image-preview img { aspect-ratio: 16 / 10; border-radius: 12px; display: block; object-fit: cover; width: 100%; }
  .admin-main-image-frame img { height: 100%; }
  .admin-main-image-replace {
    align-items: center;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.38), rgba(0, 0, 0, 0.68));
    border: 1px dashed rgba(255, 255, 255, 0.5);
    border-radius: 12px;
    color: #fff;
    cursor: pointer;
    display: flex;
    font: 800 15px/1.35 Inter, system-ui, sans-serif;
    inset: 0;
    justify-content: center;
    letter-spacing: 0.04em;
    padding: 24px;
    position: absolute;
    text-align: center;
    text-transform: uppercase;
  }
  .admin-main-image-replace:hover, .admin-main-image-current.is-drag-over .admin-main-image-replace { background: rgba(0, 0, 0, 0.72); border-color: var(--admin-accent); }
  .admin-main-image-revert {
    background: rgba(255, 117, 117, 0.94);
    border: 0;
    border-radius: 999px;
    color: #120303;
    cursor: pointer;
    font: 800 12px/1 Inter, system-ui, sans-serif;
    padding: 10px 13px;
    position: absolute;
    right: 12px;
    text-transform: uppercase;
    top: 12px;
    z-index: 2;
  }
  .admin-main-image-revert:hover { background: #ff9090; }
  .admin-main-image-revert[hidden] { display: none; }
  .admin-main-image-current p, .admin-main-image-preview p { margin: 0; }
  .admin-main-image-preview[hidden] { display: none; }
  .admin-main-image-selection { align-items: center; display: flex; flex-wrap: wrap; gap: 8px; }
  .admin-main-image-selection[hidden] { display: none; }
  .admin-upload-zone {
    align-items: center;
    border: 1px dashed rgba(143, 168, 255, 0.5);
    border-radius: 20px;
    display: flex;
    gap: 18px;
    justify-content: space-between;
    padding: 22px;
    transition: background-color 160ms ease, border-color 160ms ease, transform 160ms ease;
  }
  .admin-upload-zone.is-drag-over { background: rgba(143, 168, 255, 0.1); border-color: var(--admin-accent); transform: translateY(-1px); }
  .admin-upload-zone strong { color: #fff; display: block; font-size: 18px; margin-bottom: 6px; }
  .admin-upload-zone p { margin: 0; }
  .admin-video-upload {
    align-items: center;
    border: 1px dashed rgba(143, 168, 255, 0.5);
    border-radius: 20px;
    display: flex;
    gap: 18px;
    justify-content: space-between;
    padding: 22px;
    transition: background-color 160ms ease, border-color 160ms ease, transform 160ms ease;
  }
  .admin-video-upload.is-drag-over { background: rgba(143, 168, 255, 0.1); border-color: var(--admin-accent); transform: translateY(-1px); }
  .admin-video-upload strong { color: #fff; display: block; font-size: 18px; margin-bottom: 6px; }
  .admin-video-upload p { margin: 0; }
  .admin-video-current, .admin-video-preview {
    border: 1px solid var(--admin-line);
    border-radius: 18px;
    display: grid;
    gap: 12px;
    overflow: hidden;
    padding: 12px;
    position: relative;
    transition: border-color 160ms ease, opacity 160ms ease;
  }
  .admin-video-current[hidden], .admin-video-current video[hidden], .admin-video-preview[hidden], .admin-video-preview video[hidden], .admin-alert[hidden], .admin-upload-modal[hidden], .admin-upload-modal [hidden] { display: none; }
  .admin-video-current.is-removing { border-color: rgba(255, 117, 117, 0.7); opacity: 0.72; }
  .admin-video-preview__header { align-items: flex-start; display: flex; gap: 14px; justify-content: space-between; }
  .admin-video-preview__header p { margin: 0 0 6px; }
  .admin-video-preview__header strong { color: #fff; display: block; font-size: 14px; line-height: 1.4; word-break: break-word; }
  .admin-video-preview__header span { display: inline-block; font-size: 12px; margin-right: 10px; margin-top: 5px; }
  .admin-video-actions { display: flex; flex-wrap: wrap; gap: 8px; justify-content: flex-end; }
  .admin-video-current p, .admin-video-preview p { margin: 0; }
  .admin-video-current video, .admin-video-preview video { aspect-ratio: 16 / 9; background: #050505; border-radius: 12px; display: block; width: 100%; }
  .admin-video-lazy {
    align-items: center;
    aspect-ratio: 16 / 9;
    background: radial-gradient(circle at center, rgba(143, 168, 255, 0.18), rgba(5, 5, 5, 0.96) 58%);
    border: 1px solid rgba(143, 168, 255, 0.22);
    border-radius: 12px;
    color: var(--admin-text);
    cursor: pointer;
    display: flex;
    gap: 14px;
    justify-content: center;
    padding: 20px;
    text-align: left;
    transition: border-color 160ms ease, transform 160ms ease;
    width: 100%;
  }
  .admin-video-lazy:hover { border-color: rgba(143, 168, 255, 0.7); transform: translateY(-1px); }
  .admin-video-lazy[hidden] { display: none; }
  .admin-video-lazy strong { color: #fff; display: block; font-size: 15px; margin-bottom: 4px; }
  .admin-video-lazy span span { color: var(--admin-muted); display: block; font-size: 13px; }
  .admin-video-lazy__icon { align-items: center; background: var(--admin-accent); border-radius: 999px; color: #08101f; display: flex; flex: 0 0 44px; font-size: 18px; height: 44px; justify-content: center; line-height: 1; width: 44px; }
  .admin-checkbox { align-items: center; color: var(--admin-text); display: flex; gap: 8px; font-size: 13px; font-weight: 700; padding-bottom: 15px; text-transform: uppercase; }
  .admin-checkbox--inline { padding-bottom: 0; }
  .admin-alert { border: 1px solid rgba(255, 117, 117, 0.45); border-radius: 14px; color: var(--admin-danger); margin-bottom: 18px; padding: 14px 16px; }
  .admin-alert--compact { margin: 0; padding: 11px 13px; }
  .admin-alert--good { border-color: rgba(167, 255, 131, 0.5); color: var(--admin-good); margin: 0; }
  .admin-upload-modal {
    align-items: center;
    background: rgba(0, 0, 0, 0.78);
    backdrop-filter: blur(8px);
    display: flex;
    inset: 0;
    justify-content: center;
    padding: 24px;
    position: fixed;
    z-index: 1000;
  }
  .admin-upload-modal__card {
    align-items: center;
    border: 1px solid rgba(143, 168, 255, 0.35);
    border-radius: 28px;
    background: radial-gradient(circle at top, rgba(143, 168, 255, 0.18), transparent 46%), #111;
    box-shadow: 0 28px 100px rgba(0, 0, 0, 0.58);
    display: grid;
    gap: 22px;
    justify-items: center;
    max-width: 380px;
    padding: 34px;
    text-align: center;
    width: min(100%, 380px);
  }
  .admin-upload-progress {
    --upload-progress: 0%;
    align-items: center;
    animation: admin-upload-spin 1.1s linear infinite;
    background: conic-gradient(var(--admin-accent) var(--upload-progress), rgba(255, 255, 255, 0.12) 0);
    border-radius: 50%;
    display: flex;
    height: 148px;
    justify-content: center;
    padding: 9px;
    width: 148px;
  }
  .admin-upload-progress__inner {
    align-items: center;
    background: #111;
    border-radius: 50%;
    display: flex;
    height: 100%;
    justify-content: center;
    width: 100%;
  }
  .admin-upload-progress__inner strong {
    animation: admin-upload-spin 1.1s linear infinite reverse;
    color: #fff;
    font: 800 34px/1 Inter, system-ui, sans-serif;
  }
  .admin-upload-modal__copy h2 { color: #fff; font-size: 22px; margin: 0 0 8px; }
  .admin-upload-modal__copy p { color: var(--admin-muted); line-height: 1.5; margin: 0; }
  .admin-upload-modal.is-error .admin-upload-progress { animation: none; background: conic-gradient(var(--admin-danger) 100%, rgba(255, 255, 255, 0.12) 0); }
  .admin-upload-modal.is-error .admin-upload-progress__inner strong { animation: none; color: var(--admin-danger); font-size: 26px; }

  @keyframes admin-upload-spin {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 840px) {
    body.admin-shell { display: block; }
