---
---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo-link" aria-label="TG Agency">
      <img src="/images/tg-logo.png" alt="TG" class="logo" />
    </a>

    <nav class="nav" aria-label="Principal">
      <a href="#cases">Cases</a>
      <a href="#historia">Nossa história</a>
      <a href="#noticias">Notícias TG</a>
      <a href="#global">Conexão global</a>
    </nav>

    <div class="header-actions">
      <a href="#contato" class="btn-contato">Contato</a>
      <a href="https://wa.me/" class="whatsapp-link" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
        <img src="/images/whatsapp.svg" alt="" aria-hidden="true" />
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 120px;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.75) 0%, rgba(0, 0, 0, 0) 100%);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0 2.84%;
  }

  /* Logo */
  .logo-link {
    flex-shrink: 0;
  }

  .logo {
    height: 52px;
    width: auto;
    display: block;
  }

  /* Nav */
  .nav {
    display: flex;
    gap: 2.5rem;
    align-items: center;
  }

  .nav a {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    color: #fff;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: opacity 0.15s ease;
  }

  .nav a:hover {
    opacity: 0.7;
  }

  /* Actions (Contato + WhatsApp) */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .btn-contato {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 59px;
    padding: 0 2rem;
    border: 2px solid #6789d9;
    border-radius: 33px;
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: background-color 0.15s ease;
  }

  .btn-contato:hover {
    background-color: rgba(103, 137, 217, 0.15);
  }

  .whatsapp-link {
    display: flex;
    align-items: center;
  }

  .whatsapp-link img {
    height: 44px;
    width: auto;
  }
</style>
