---
const features = [
  { icon: "/images/wpi/icon-insights.svg",  label: "Insights\ninternacionais" },
  { icon: "/images/wpi/icon-parcerias.svg", label: "Parcerias\nglobais" },
  { icon: "/images/wpi/icon-troca.svg",     label: "Troca de\nexperiências" },
  { icon: "/images/wpi/icon-squads.svg",    label: "Squads com\nespecialistas" },
];
---

<section class="wpi-section" id="global">
  <!-- Top: globe card + text -->
  <div class="wpi-top">

    <!-- Left: earth globe card with logos -->
    <div class="wpi-card-col">
      <div class="wpi-card">
        <img src="/images/wpi/worldmap.png" alt="" class="wpi-worldmap" aria-hidden="true" />
        <img src="/images/wpi/earth.png" alt="Vista do planeta Terra" class="wpi-earth" />
        <div class="wpi-logos">
          <img src="/images/wpi/wpi-logo.png" alt="Worldwide Partners" class="logo-wpi" />
          <div class="logo-divider" aria-hidden="true"></div>
          <img src="/images/wpi/tg-logo.png" alt="TG" class="logo-tg" />
        </div>
      </div>
    </div>

    <!-- Right: title + body + CTA -->
    <div class="wpi-text">
      <h2 class="wpi-title">
        <span class="wpi-gradient">Aqui tem</span>
        <span class="wpi-white"> conexão<br />global.</span>
      </h2>
      <p class="wpi-body">
        Somos parte da Worldwide Partners Inc.,<br />
        a maior rede de agências independentes<br />
        do mundo.
      </p>
      <a href="/wpi" class="site-button site-button--gradient btn-rede">Conheça a rede</a>
    </div>
  </div>

  <!-- Tagline -->
  <p class="wpi-tagline">
    <strong>100% independentes,</strong>
    conectados a mais de 90 agências, em mais de 50 países.
  </p>

  <!-- Feature icons row -->
  <div class="wpi-features">
    {features.map((f) => (
      <div class="feature">
        <div class="feature-icon-wrap">
          <img src="/images/wpi/blob.png" alt="" class="feature-blob" aria-hidden="true" />
          <img src={f.icon} alt="" class="feature-icon" aria-hidden="true" />
        </div>
        <p class="feature-label">{f.label}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .wpi-section {
    background-color: #0d0d0d;
    background-image: url('/images/degrade-pixels.png');
    background-size: auto;
    background-repeat: repeat-x;
    background-position: 0 center;
    background-blend-mode: hard-light;
    animation: bg-pan-x 240s linear infinite reverse;
    width: 100%;
    padding: 5rem 8.4%;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  /* ── Top row ─────────────────────────────────── */
  .wpi-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
  }

  /* Globe card */
  .wpi-card-col {
    display: flex;
    align-items: center;
  }

  .wpi-card {
    position: relative;
    width: 100%;
    border-radius: 40px;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: #000;
  }

  .wpi-earth {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .wpi-worldmap {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
    mix-blend-mode: screen;
    z-index: 1;
    pointer-events: none;
  }

  .wpi-logos {
    position: absolute;
    top: 1.25rem;
    left: 1.25rem;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo-wpi {
    height: 36px;
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .logo-divider {
    width: 1px;
    height: 40px;
    background: rgba(255,255,255,0.6);
  }

  .logo-tg {
    height: 40px;
    width: auto;
    object-fit: contain;
  }

  /* Text column */
  .wpi-text {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .wpi-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5.2vw, 6.25rem);
    font-weight: 400;
    line-height: 1.05;
    text-transform: uppercase;
  }

  .wpi-gradient {
    background: linear-gradient(
      90deg,
      rgb(94, 136, 237) 0%,
      rgb(180, 64, 200) 19%,
      rgb(242, 137, 0) 38%,
      rgb(247, 214, 0) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .wpi-white {
    color: #fff;
  }

  .wpi-body {
    font-family: 'Inter', sans-serif;
    font-size: clamp(1rem, 1.67vw, 2rem);
    font-weight: 400;
    line-height: 1.5;
    color: #fff;
  }

  .btn-rede {
    align-self: flex-start;
  }

  /* ── Tagline ─────────────────────────────────── */
  .wpi-tagline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.5rem, 2.5vw, 3rem);
    font-weight: 400;
    color: #fff;
    text-transform: uppercase;
    text-align: center;
    line-height: 1.1;
  }

  .wpi-tagline strong {
    font-weight: 700;
  }

  /* ── Feature icons row ───────────────────────── */
  .wpi-features {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  .feature-icon-wrap {
    position: relative;
    width: 100px;
    height: 100px;
  }

  @keyframes blob-float {
    0%   { transform: scale(1)    rotate(0deg)   translate(0px, 0px); }
    25%  { transform: scale(1.04) rotate(4deg)   translate(2px, -3px); }
    50%  { transform: scale(0.97) rotate(-2deg)  translate(-2px, 2px); }
    75%  { transform: scale(1.03) rotate(3deg)   translate(1px, -2px); }
    100% { transform: scale(1)    rotate(0deg)   translate(0px, 0px); }
  }

  .feature-blob {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    animation: blob-float 6s ease-in-out infinite;
    transform-origin: center;
  }

  .feature:nth-child(2) .feature-blob { animation-delay: -1.5s; animation-duration: 7s; }
  .feature:nth-child(3) .feature-blob { animation-delay: -3s;   animation-duration: 5.5s; }
  .feature:nth-child(4) .feature-blob { animation-delay: -4.5s; animation-duration: 6.5s; }

  .feature-icon {
    position: absolute;
    inset: 20%;
    width: 60%;
    height: 60%;
    object-fit: contain;
  }

  .feature-label {
    font-family: 'Inter', sans-serif;
    font-size: clamp(0.85rem, 1.1vw, 1.3rem);
    font-weight: 700;
    color: #fff;
    text-align: center;
    line-height: 1.3;
    white-space: pre-line;
  }

  @media (max-width: 768px) {
    .wpi-section {
      padding: 3.5rem 1.5rem;
      gap: 2.5rem;
    }

    .wpi-top {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .wpi-features {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }
</style>
