---
---
<section class="hero-section">
  <!-- Background photo -->
  <img
    src="/images/hero-bg.png"
    alt=""
    class="hero-bg"
    aria-hidden="true"
  />

  <!-- "AQUI TEM SOLUÇÃO" gradient headline -->
  <img
    src="/images/hero-headline.png"
    alt="Aqui tem solução"
    class="hero-headline"
  />

  <!-- Bottom bar: social icons + address -->
  <div class="hero-footer">
    <div class="social-icons" aria-label="Redes sociais">
      <img src="/images/linkedin.svg" alt="LinkedIn" />
      <img src="/images/youtube.svg" alt="YouTube" />
    </div>

    <address class="hero-address">
      Av. Eng. Luis Carlos Berrini, 1700<br />
      16º andar, São Paulo – SP – Brasil
    </address>
  </div>

  <!-- Scroll indicator arrow -->
  <button class="scroll-arrow" aria-label="Rolar para baixo" onclick="document.getElementById('cases').scrollIntoView({behavior:'smooth'})">
    <img src="/images/hero-vector.svg" alt="" width="23" height="29" />
  </button>
</section>

<style>
  .hero-section {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 500px;
    overflow: hidden;
  }

  /* Background photo */
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    pointer-events: none;
  }

  /* Gradient headline — positioned at ~45% from top, 7.9% from left */
  .hero-headline {
    position: absolute;
    top: 44.9%;
    left: 7.9%;
    width: 83.9%;
    height: auto;
    pointer-events: none;
  }

  /* Bottom bar */
  .hero-footer {
    position: absolute;
    bottom: 4%;
    left: 3%;
    right: 3%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .social-icons {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .social-icons img {
    width: 34px;
    height: 34px;
  }

  .hero-address {
    font-family: 'Inter', sans-serif;
    font-style: normal;
    font-size: 1.09rem; /* ~17.4px */
    line-height: 1.4;
    color: #fff;
    text-align: right;
  }

  /* Scroll-down arrow — bottom center */
  .scroll-arrow {
    position: absolute;
    bottom: 4%;
    left: 50%;
    transform: translateX(-50%) rotate(180deg);
    opacity: 0.6;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .scroll-arrow:hover {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .hero-address {
      font-size: 0.85rem;
    }
  }

  @media (max-width: 480px) {
    .hero-address {
      display: none;
    }
  }
</style>
