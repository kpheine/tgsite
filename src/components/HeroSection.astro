---
---
<section class="hero-section">
  <!-- Background photo -->
  <img
    src="/images/hero-bg.png"
    alt=""
    class="hero-bg"
    aria-hidden="true"
  />

  <h1
    class="hero-headline"
    aria-label="Aqui tem estratégia, criatividade, inteligência, análise, planejamento e solução"
  >
    <span class="hero-headline__prefix">AQUI TEM</span>
    <span class="hero-headline__typed" data-hero-typed-word>Estratégia</span><span
      class="hero-headline__cursor is-idle"
      data-hero-typing-cursor
      aria-hidden="true"
    >_</span>
  </h1>

  <!-- Bottom bar: social icons + address -->
  <div class="hero-footer">
    <div class="social-icons" aria-label="Redes sociais">
      <img src="/images/linkedin.svg" alt="LinkedIn" />
      <img src="/images/youtube.svg" alt="YouTube" />
    </div>

    <address class="hero-address">
      Av. Eng. Luis Carlos Berrini, 1700<br />
      16º andar, São Paulo – SP – Brasil
    </address>
  </div>

  <!-- Scroll indicator arrow -->
  <button class="scroll-arrow" aria-label="Rolar para baixo" onclick="document.getElementById('cases').scrollIntoView({behavior:'smooth'})">
    <img src="/images/hero-vector.svg" alt="" width="23" height="29" />
  </button>
</section>

<script>
  const typedWord = document.querySelector<HTMLElement>('[data-hero-typed-word]');
  const cursor = document.querySelector<HTMLElement>('[data-hero-typing-cursor]');
  const words = ['Estratégia', 'Criatividade', 'Inteligência', 'Análise', 'Planejamento', 'Solução'];
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (typedWord && cursor && !prefersReducedMotion) {
    let wordIndex = 0;
    let characterIndex = words[wordIndex].length;
    let isDeleting = true;

    const setIdle = (isIdle: boolean) => {
      cursor.classList.toggle('is-idle', isIdle);
    };

    const scheduleNextStep = (delay: number) => {
      window.setTimeout(typeNextCharacter, delay);
    };

    const typeNextCharacter = () => {
      const currentWord = words[wordIndex];
      setIdle(false);

      if (isDeleting) {
        characterIndex -= 1;
        typedWord.textContent = currentWord.slice(0, characterIndex);

        if (characterIndex === 0) {
          isDeleting = false;
          wordIndex = (wordIndex + 1) % words.length;
          scheduleNextStep(260);
          return;
        }

        scheduleNextStep(58);
        return;
      }

      const nextWord = words[wordIndex];
      characterIndex += 1;
      typedWord.textContent = nextWord.slice(0, characterIndex);

      if (characterIndex === nextWord.length) {
        setIdle(true);
        isDeleting = true;
        scheduleNextStep(3200);
        return;
      }

      scheduleNextStep(95);
    };

    window.setTimeout(typeNextCharacter, 1600);
  }
</script>

<style>
  .hero-section {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 500px;
    overflow: hidden;
  }

  /* Background photo */
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    pointer-events: none;
  }

  .hero-headline {
    position: absolute;
    top: 44.9%;
    left: 50%;
    transform: translateX(-50%);
    width: 83.9%;
    color: #fff;
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: clamp(4rem, 8.6vw, 8.8rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 0.86;
    pointer-events: none;
    text-align: center;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .hero-headline__prefix {
    background: linear-gradient(100deg, #3157d6 0%, #23d6ec 28%, #ec148f 55%, #3157d6 82%, #23d6ec 100%);
    background-size: 240% 100%;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: hero-gradient-cycle 30s ease-in-out infinite;
  }

  .hero-headline__typed,
  .hero-headline__cursor {
    color: #fff;
  }

  .hero-headline__cursor {
    opacity: 1;
  }

  .hero-headline__cursor.is-idle {
    animation: hero-cursor-blink 1.2s steps(1, end) infinite;
  }

  @keyframes hero-cursor-blink {
    0%, 45% {
      opacity: 1;
    }

    46%, 100% {
      opacity: 0;
    }
  }

  @keyframes hero-gradient-cycle {
    0%, 100% {
      background-position: 0% 50%;
    }

    50% {
      background-position: 100% 50%;
    }
  }

  /* Bottom bar */
  .hero-footer {
    position: absolute;
    bottom: 4%;
    left: 3%;
    right: 3%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .social-icons {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .social-icons img {
    width: 34px;
    height: 34px;
  }

  .hero-address {
    font-family: 'Inter', sans-serif;
    font-style: normal;
    font-size: 1.09rem; /* ~17.4px */
    line-height: 1.4;
    color: #fff;
    text-align: right;
  }

  /* Scroll-down arrow — bottom center */
  .scroll-arrow {
    position: absolute;
    bottom: 4%;
    left: 50%;
    transform: translateX(-50%) rotate(180deg);
    opacity: 0.6;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .scroll-arrow:hover {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .hero-headline {
      font-size: clamp(3.1rem, 8.7vw, 5rem);
    }

    .hero-address {
      font-size: 0.85rem;
    }
  }

  @media (max-width: 480px) {
    .hero-headline {
      top: 42%;
      left: 50%;
      width: 88%;
      font-size: clamp(2.25rem, 15vw, 4.4rem);
      white-space: normal;
    }

    .hero-address {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-headline__prefix,
    .hero-headline__cursor.is-idle {
      animation: none;
    }
  }
</style>
