---
import Modal from './Modal.astro';
---

<Modal id="contact-modal" ariaLabel="Contato" className="contact-modal">
  <div class="contact-success-overlay" aria-hidden="true">
    <svg class="contact-success-overlay__check" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="32" cy="32" r="31" stroke="white" stroke-width="2" stroke-opacity="0.3"/>
      <polyline points="18,33 28,43 46,22" stroke="white" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <p class="contact-success-overlay__label">Enviado!</p>
  </div>

  <div class="contact-modal__content">
    <section class="contact-modal__form-area" aria-labelledby="contact-modal-title">
      <h2 id="contact-modal-title" class="contact-modal__title">Fale com a gente.</h2>

      <form class="contact-modal__form">
        <div class="contact-modal__row">
          <label class="contact-modal__field">
            <span class="sr-only">Nome</span>
            <input type="text" name="nome" placeholder="Nome" autocomplete="given-name" />
          </label>

          <label class="contact-modal__field">
            <span class="sr-only">Sobrenome</span>
            <input type="text" name="sobrenome" placeholder="Sobrenome" autocomplete="family-name" />
          </label>
        </div>

        <label class="contact-modal__field">
          <span class="sr-only">Email</span>
          <input type="email" name="email" placeholder="Email" autocomplete="email" />
        </label>

        <label class="contact-modal__field">
          <span class="sr-only">Telefone</span>
          <input type="tel" name="telefone" placeholder="Telefone" autocomplete="tel" />
        </label>

        <label class="contact-modal__field">
          <span class="sr-only">Mensagem</span>
          <textarea name="mensagem" placeholder="Mensagem" rows="4"></textarea>
        </label>

        <div class="contact-modal__actions">
          <button class="site-button site-button--gradient contact-modal__submit" type="button" data-state="idle">
            <span class="btn-label">Enviar</span>
            <span class="btn-loading" aria-hidden="true">
              <span class="btn-spinner"></span>
              Enviando...
            </span>
            <span class="btn-error" aria-live="polite">✕ Algo deu errado</span>
          </button>
          <a href="https://wa.me/" class="contact-modal__whatsapp" target="_blank" rel="noopener noreferrer" aria-label="Falar pelo WhatsApp">
            <img src="/images/whatsapp.svg" alt="" aria-hidden="true" />
          </a>
        </div>
      </form>
    </section>

    <div class="contact-modal__brand" aria-hidden="true">
      <img src="/images/tg-logo.png" alt="" />
    </div>
  </div>
</Modal>

<style>
  :global(.contact-modal) {
    width: min(858px, calc(100vw - 2rem));
    border-radius: 16px;
  }

  :global(.contact-modal .modal__panel) {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(80, 36, 100, 0.36);
    background:
      radial-gradient(circle at 4% 5%, rgba(105, 42, 148, 0.16), transparent 33%),
      linear-gradient(110deg, #1b1624 0%, #08090c 51%, #101018 100%);
    box-shadow: 0 26px 80px rgba(0, 0, 0, 0.72);
    padding: 48px 49px 46px;
  }

  .contact-success-overlay {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    background: linear-gradient(135deg, #0a3d24 0%, #1a7a4a 100%);
    opacity: 0;
    pointer-events: none;
    transition: opacity 300ms ease;
  }

  .contact-success-overlay.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  .contact-success-overlay__check {
    width: 80px;
    height: 80px;
  }

  .contact-success-overlay__label {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 5vw, 4.5rem);
    font-weight: 400;
    color: #fff;
    margin: 0;
    letter-spacing: 0.02em;
  }

  :global(.contact-modal .modal__close) {
    top: 15px;
    right: 14px;
    width: 18px;
    height: 18px;
    color: #f4f4f7;
    font-size: 30px;
    line-height: 18px;
  }

  .contact-modal__content {
    display: grid;
    grid-template-columns: minmax(0, 375px) minmax(260px, 1fr);
    align-items: center;
    gap: 32px;
    min-height: 374px;
  }

  .contact-modal__title {
    color: #f5f3f7;
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3.25rem, 5vw, 4.25rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 0.98;
    margin: 0 0 38px;
    text-transform: uppercase;
  }

  .contact-modal__form {
    display: grid;
    gap: 9px;
  }

  .contact-modal__row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 9px;
  }

  .contact-modal__field {
    display: block;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .contact-modal__field input,
  .contact-modal__field textarea {
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.17);
    border-radius: 4px;
    background: linear-gradient(135deg, rgba(33, 28, 40, 0.9), rgba(22, 23, 28, 0.88));
    color: #f3f3f6;
    font: 400 12px/1.2 'Inter', system-ui, sans-serif;
    outline: none;
    padding: 0 11px;
    transition: border-color 160ms ease, box-shadow 160ms ease;
  }

  .contact-modal__field input {
    height: 34px;
  }

  .contact-modal__field textarea {
    height: 86px;
    padding-top: 11px;
    resize: none;
  }

  .contact-modal__field input::placeholder,
  .contact-modal__field textarea::placeholder {
    color: rgba(231, 231, 238, 0.62);
  }

  .contact-modal__field input:focus,
  .contact-modal__field textarea:focus {
    border-color: rgba(98, 229, 255, 0.72);
    box-shadow: 0 0 0 2px rgba(98, 229, 255, 0.12);
  }

  .contact-modal__actions {
    display: grid;
    grid-template-columns: minmax(0, 291px) 49px;
    align-items: center;
    gap: 37px;
    margin-top: 1px;
  }

  .contact-modal__submit {
    --site-button-padding: 0.9rem 2.5rem;
    --site-button-font-size: 18px;
    --site-button-letter-spacing: 0;
    border-radius: 999px;
    font-weight: 800;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: opacity 160ms ease;
  }

  /* Hide all state content by default */
  .btn-label, .btn-loading, .btn-success, .btn-error { display: none; }

  /* idle */
  .contact-modal__submit[data-state="idle"] .btn-label { display: inline; }

  /* loading */
  .contact-modal__submit[data-state="loading"] .btn-loading { display: inline-flex; align-items: center; gap: 8px; }
  .contact-modal__submit[data-state="loading"] { pointer-events: none; opacity: 0.8; }

  /* error */
  .contact-modal__submit[data-state="error"] .btn-error { display: inline; }
  .contact-modal__submit[data-state="error"] {
    background: linear-gradient(135deg, #7a1a2a, #c0302b) !important;
  }

  .btn-spinner {
    width: 15px;
    height: 15px;
    border: 2px solid rgba(255, 255, 255, 0.35);
    border-top-color: #fff;
    border-radius: 50%;
    flex-shrink: 0;
    animation: contact-spin 0.7s linear infinite;
  }

  @keyframes contact-spin {
    to { transform: rotate(360deg); }
  }

  .contact-modal__whatsapp:hover {
    filter: brightness(1.25);
  }

  .contact-modal__whatsapp {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 49px;
    height: 49px;
    transition: filter 160ms ease, transform 160ms ease;
  }

  .contact-modal__whatsapp img {
    width: 49px;
    height: 49px;
    object-fit: contain;
  }

  .contact-modal__brand {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 248px;
  }

  .contact-modal__brand img {
    display: block;
    width: min(344px, 100%);
    height: auto;
    filter: saturate(1.18) contrast(1.06);
  }

  @media (max-width: 760px) {
    :global(.contact-modal .modal__panel) {
      min-height: 100dvh;
      padding: 58px 24px 34px;
    }

    .contact-modal__content {
      grid-template-columns: 1fr;
      gap: 32px;
      min-height: 0;
    }

    .contact-modal__title {
      margin-bottom: 28px;
    }

    .contact-modal__actions {
      grid-template-columns: minmax(0, 1fr) 49px;
      gap: 18px;
    }

    .contact-modal__brand {
      min-height: 180px;
      order: -1;
    }

    .contact-modal__brand img {
      width: min(190px, 72vw);
    }
  }

  @media (max-width: 460px) {
    .contact-modal__row {
      grid-template-columns: 1fr;
    }

    .contact-modal__actions {
      grid-template-columns: 1fr;
    }

    .contact-modal__whatsapp {
      justify-self: center;
    }
  }
</style>

<script>
  const dialog    = document.getElementById('contact-modal') as HTMLDialogElement;
  const submitBtn = document.querySelector<HTMLButtonElement>('.contact-modal__submit');
  const overlay   = document.querySelector<HTMLElement>('.contact-success-overlay');

  function setState(state: 'idle' | 'loading' | 'error') {
    if (!submitBtn) return;
    submitBtn.dataset.state = state;
    submitBtn.disabled = state === 'loading';
  }

  function showSuccess() {
    overlay?.classList.add('is-visible');
    setTimeout(() => {
      dialog?.querySelector<HTMLButtonElement>('[data-modal-close]')?.click();
    }, 1000);
  }

  dialog?.addEventListener('close', () => {
    overlay?.classList.remove('is-visible');
    setState('idle');
  });

  submitBtn?.addEventListener('click', async () => {
    setState('loading');

    const form = document.querySelector<HTMLFormElement>('.contact-modal__form');
    const data = form ? Object.fromEntries(new FormData(form)) : {};

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (!res.ok) throw new Error('send failed');

      showSuccess();
      form?.reset();
    } catch {
      setState('error');
      setTimeout(() => setState('idle'), 3000);
    }
  });
</script>
