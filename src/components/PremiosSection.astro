---
---
<section class="premios-section" id="premios">
  <div class="premios-inner">

    <!-- Left: title + award logos + CTA -->
    <div class="premios-text">
      <h2 class="premios-title">
        <span class="title-gradient">Aqui tem</span>
        <span class="title-white"> reconhecimento<br />que atravessa<br />fronteiras.</span>
      </h2>

      <div class="award-logos">
        <div class="award-row">
          <img src="/images/premios/live.png"      alt="Prêmio Live Marketing" />
          <img src="/images/premios/fip.png"        alt="FIP" />
          <img src="/images/premios/caio.png"       alt="Prêmio Caio" />
        </div>
        <div class="award-row">
          <img src="/images/premios/colunistas.png" alt="Prêmio Colunistas" />
          <img src="/images/premios/lusofonos.png"  alt="Prêmio Lusófonos da Criatividade" />
        </div>
      </div>

      <a href="/sobre#premios" class="site-button site-button--gradient btn-premios">Veja nossas conquistas</a>
    </div>

    <!-- Right: awards collage -->
    <div class="premios-image-col">
      <img
        src="/images/premios/collage.png"
        alt="Troféus e prêmios TG"
        class="premios-collage"
      />
    </div>

  </div>
</section>

<style>
  .premios-section {
    background-color: #0d0d0d;
    width: 100%;
  }

  .premios-inner {
    display: grid;
    grid-template-columns: 5fr 7fr;
    align-items: center;
    min-height: 100svh;
    padding: 5rem 0 5rem 8.4%;
    gap: 4rem;
  }

  /* ── Left column ─────────────────────────────── */
  .premios-text {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .premios-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5.2vw, 6.25rem);
    font-weight: 400;
    line-height: 1.05;
    text-transform: uppercase;
  }

  .title-gradient {
    background: linear-gradient(
      -82.73deg,
      rgb(103, 137, 217) 5%,
      rgb(37, 62, 173) 18%,
      rgb(33, 110, 242) 32%,
      rgb(98, 229, 255) 53%,
      rgb(163, 67, 203) 72%,
      rgb(234, 14, 129) 93%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .title-white {
    color: #fff;
  }

  /* Award logo rows */
  .award-logos {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .award-row {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .award-row img {
    height: 56px;
    width: auto;
    max-width: 200px;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.9;
  }

  /* CTA button */
  .btn-premios {
    align-self: flex-start;
  }

  /* ── Right column — no right padding, bleeds to edge ── */
  .premios-image-col {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    overflow: hidden;
  }

  .premios-collage {
    width: 100%;
    height: auto;
    object-fit: contain;
    object-position: left center;
    display: block;
  }
</style>
