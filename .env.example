ADMIN_PATH=/painel-tg-2026
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
SESSION_SECRET=replace-with-a-long-random-secret
HOST=0.0.0.0
PORT=4321
ALLOWED_HOSTS=localhost,127.0.0.1
SESSION_COOKIE_SECURE=true
TRUST_PROXY_HEADERS=true
UPLOAD_MAX_IMAGE_BYTES=8388608

# Contact form — Gmail SMTP
# SMTP_USER: the Gmail address used to send emails (needs an App Password)
# SMTP_PASS: the 16-character App Password (Google Account → Security → App Passwords)
# CONTACT_TO: the recipient address where contact form emails should land
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
CONTACT_TO=recipient@yourdomain.com
